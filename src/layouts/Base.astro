---
import { Image } from 'astro:assets';
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import "../styles/global.css";
import "../styles/cards.css";
import "../styles/pages/about.css";
import "../styles/pages/home.css";
import "../styles/pages/services.css";
import "../styles/pages/portfolio.css";
import "../styles/pages/work.css";
import "../styles/components.css";
import "../styles/preview.css";
import { site } from "../data/site.ts";
import { organizationSchema, breadcrumbSchema, getBreadcrumbs } from "../utils/schema";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  schema?: any;
}

const {
  title = site.name,
  description = site.tagline,
  image = site.ogImage,
  type = 'website',
  schema,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).toString();
const pageTitle = title === site.name ? site.name : `${title} — Roha`;
const ogImage = image.startsWith('http') ? image : `${site.url}${image}`;

// Get breadcrumbs for schema
const { isHomepage, breadcrumbs: breadcrumbList } = getBreadcrumbs(Astro.url.pathname);
const includeHomepage = [{ label: 'Home', href: '/' }, ...breadcrumbList];
const orgSchema = organizationSchema(site.url);
const breadcrumbListSchema = breadcrumbSchema(includeHomepage, site.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbListSchema)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <link
      rel="icon"
      type="image/svg+xml"
      href="https://ik.imagekit.io/gorat/roha.png?updatedAt=1779127109052"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..800&family=Geist:wght@300..700&family=Geist+Mono:wght@400..600&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <Breadcrumb />
    <main>
      <slot />
    </main>

    <Footer />

    <a
      href={`https://wa.me/${site.wa}?text=Halo%20Roha%2C%20saya%20ingin%20diskusi%20project%20bareng.`}
      class="wa-fab"
      target="_blank"
      rel="noopener"
      aria-label="Chat on WhatsApp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      <span>Let&rsquo;s Talk</span>
    </a>

    <script src="../scripts/main.js"></script>
    <script src="../scripts/preview.js"></script>
  </body>
</html>
