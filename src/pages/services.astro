          <p class="launch-note">Starting rates for basic scope. Final price depends on your needs. We'll quote it before we begin.</p>
        </div>

        <div class="svc-cards">

          <!-- 01 Product Design -->
          <article class="svc-card" id="product-design" data-reveal data-reveal-delay="0">
            <div class="svc-cover" aria-hidden="true">
