---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allWork = await getCollection('work', ({ data }) => !data.draft);
const sortedWork = allWork.sort((a, b) => a.data.order - b.data.order).slice(0, 2);

const allPortfolio = await getCollection('portfolio', ({ data }) => !data.draft);
const sortedPortfolio = allPortfolio.sort((a, b) => a.data.order - b.data.order).slice(0, 3);
---

<Base
  title="Roha"
  description="Roha is a small studio that helps founders and indie makers build websites, UI/UX, and brands that feel real — not just thrown together."
>
  <main id="main">

  <!-- =================== HERO =================== -->
  <section class="home-hero">
    <div class="wrap">
      <div class="eyebrow">Design Studio · Est. 2020</div>

      <div class="home-hero-grid">
        <h1 class="display">Digital design<br/>made <em class="italic-accent">warm</em>,<br/>shipped tidy.</h1>

        <div class="home-hero-meta">
          <p>Roha is a small studio that helps founders and indie makers build websites, UI/UX, and brands that feel real — not just thrown together.</p>
          <div class="btn-row">
            <a href="/work" class="btn btn-primary">See Our Work <span class="arr">→</span></a>
            <a href="/about#contact" class="btn btn-secondary">Contact Us</a>
          </div>
        </div>
      </div>

      <div class="hero-stripe" aria-hidden="true">
        <span style="background:var(--terracotta)"></span>
        <span style="background:var(--terracotta-soft)"></span>
        <span style="background:var(--mustard)"></span>
        <span style="background:var(--sand)"></span>
        <span style="background:var(--cream)"></span>
        <span style="background:var(--clay)"></span>
        <span style="background:var(--ink)"></span>
      </div>
    </div>
  </section>

  <!-- =================== PRINCIPLES =================== -->
  <section class="section">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">Our Approach</div>
          <h2>How we work.</h2>
        </div>
        <p class="right">Four things that guide every project. Design that means something, built with intention.</p>
      </div>

      <div class="principles-grid">
        <div class="principle" data-reveal>
          <div class="principle-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3>Quiet on the surface, considered underneath.</h3>
          <p>Design that doesn&rsquo;t shout, but every choice has a reason. Spacing, sizing, color — we can explain all of it.</p>
        </div>
        <div class="principle" data-reveal data-reveal-delay="100">
          <div class="principle-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Warmth is a discipline.</h3>
          <p>Warmth isn&rsquo;t an accident. It&rsquo;s chosen, measured, intentional — because we meant it, not by default.</p>
        </div>
        <div class="principle" data-reveal data-reveal-delay="200">
          <div class="principle-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          </div>
          <h3>Systems, not decoration.</h3>
          <p>We build design systems, not one pretty page. Components, tokens, documentation — so it feels right a year from now.</p>
        </div>
        <div class="principle" data-reveal data-reveal-delay="300">
          <div class="principle-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </div>
          <h3>Ship it, don&rsquo;t polish it forever.</h3>
          <p>Shipped &gt; perfect. Better a 1.0 that&rsquo;s live than a 0.9 that&rsquo;s delayed. What matters is knowing what to improve next.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== STATS =================== -->
  <section class="section">
    <div class="wrap">
      <div class="stats-grid">
        <div class="stat-card" data-reveal>
          <div class="stat-number">20+</div>
          <div class="stat-label">Projects Shipped</div>
        </div>
        <div class="stat-card" data-reveal data-reveal-delay="100">
          <div class="stat-number">4+</div>
          <div class="stat-label">Years in Business</div>
        </div>
        <div class="stat-card" data-reveal data-reveal-delay="200">
          <div class="stat-number">15+</div>
          <div class="stat-label">Happy Clients</div>
        </div>
        <div class="stat-card" data-reveal data-reveal-delay="300">
          <div class="stat-number">100%</div>
          <div class="stat-label">On-Time Delivery</div>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== TESTIMONIALS =================== -->
  <section class="section testimonials-section">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">Testimonials</div>
          <h2>What clients say.</h2>
        </div>
      </div>
    </div>

    <div class="marquee-outer" aria-label="Client testimonials">
      <div class="marquee-track">
        <!-- original set -->
        <div class="testimonial-card">
          <p class="quote">&ldquo;Roha didn&rsquo;t just build us a website — they built us a system. Every decision was intentional, and it shows.&rdquo;</p>
          <div class="testimonial-meta">
            <div class="testimonial-name">Sarah Chen</div>
            <div class="testimonial-role">Founder, Bloom Studio</div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="quote">&ldquo;The design felt warm and approachable, exactly what we needed. Plus, the handoff documentation made it easy for our dev team.&rdquo;</p>
          <div class="testimonial-meta">
            <div class="testimonial-name">Adi Wijaya</div>
            <div class="testimonial-role">Product Lead, Startup ID</div>
          </div>
        </div>
        <div class="testimonial-card">
          <p class="quote">&ldquo;We loved the process. They asked the right questions, showed us multiple directions, and were transparent about tradeoffs.&rdquo;</p>
          <div class="testimonial-meta">
            <div class="testimonial-name">Maya Patel</div>
            <div class="testimonial-role">CEO, Design Market</div>
          </div>
        </div>
        <!-- duplicate for seamless loop -->
        <div class="testimonial-card" aria-hidden="true">
          <p class="quote">&ldquo;Roha didn&rsquo;t just build us a website — they built us a system. Every decision was intentional, and it shows.&rdquo;</p>
          <div class="testimonial-meta">
            <div class="testimonial-name">Sarah Chen</div>
            <div class="testimonial-role">Founder, Bloom Studio</div>
          </div>
        </div>
        <div class="testimonial-card" aria-hidden="true">
          <p class="quote">&ldquo;The design felt warm and approachable, exactly what we needed. Plus, the handoff documentation made it easy for our dev team.&rdquo;</p>
          <div class="testimonial-meta">
            <div class="testimonial-name">Adi Wijaya</div>
            <div class="testimonial-role">Product Lead, Startup ID</div>
          </div>
        </div>
        <div class="testimonial-card" aria-hidden="true">
          <p class="quote">&ldquo;We loved the process. They asked the right questions, showed us multiple directions, and were transparent about tradeoffs.&rdquo;</p>
          <div class="testimonial-meta">
            <div class="testimonial-name">Maya Patel</div>
            <div class="testimonial-role">CEO, Design Market</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== FEATURED WORK =================== -->
  <section class="section" id="work-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">01 — Featured Work</div>
          <h2>What we&rsquo;ve shipped.</h2>
        </div>
        <p class="right">Two projects — a small list, but each has a story. Pick one to read in detail.</p>
      </div>

      <div class="featured-scroll-outer">
        <div class="featured-grid">
          {
            sortedWork.map((project, i) => {
              const { title, summary, service, year, pattern, coverImage } = project.data;
              return (
                <a href={`/work/${project.id}`} class="project-card" data-reveal data-reveal-delay={i * 120}>
                  {coverImage ? (
                    <img src={coverImage} alt={title} class="thumb" width={400} height={300} loading="lazy" />
                  ) : (
                    <div class={`thumb ${pattern} pattern-wrap`} aria-hidden="true"></div>
                  )}
                  <div class="meta-row">
                    <span class="tag">{service}</span>
                    <span class="year">{year}</span>
                  </div>
                  <h3>{title}</h3>
                  <p class="summary">{summary}</p>
                </a>
              );
            })
          }
        </div>
      </div>

      <a href="/work" class="section-link" data-reveal>All Work <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== PORTFOLIO PREVIEW =================== -->
  <section class="section" id="portfolio-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">02 — Design System &amp; Kits</div>
          <h2>Design kits we&rsquo;ve created.</h2>
        </div>
        <p class="right">Design systems and kits from our client work — proven, documented, and ready to adapt. See how we approach systematic design.</p>
      </div>

      <div class="shop-grid">
        {
          sortedPortfolio.map((item, i) => {
            const d = item.data;
            const coverImage = d.images?.[0];
            return (
              <a
                href={`/portfolio/${item.id}`}
                class="product-card"
                data-reveal
                data-reveal-delay={i * 100}
                data-preview-url={
                  d.previewPath
                    ? `/templates/${d.previewPath}/index.html`
                    : undefined
                }
                data-preview-title={d.title}
                data-preview-cat={d.category}
              >
                {d.previewPath && (
                  <span
                    class="pv-trigger"
                    role="button"
                    tabindex="0"
                    data-preview-trigger
                    aria-label={`Preview ${d.title}`}
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
                    Preview
                  </span>
                )}
                {coverImage ? (
                  <div class="cover">
                    <img src={coverImage} alt={d.title} width={350} height={280} loading="lazy" />
                  </div>
                ) : (
                  <div class={`cover ${d.pattern} pattern-wrap`} aria-hidden="true"></div>
                )}
                <div class="body">
                  <span class="cat">{d.category}</span>
                  <div class="name-row">
                    <h3 class="name">{d.title}</h3>
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>

      <a href="/portfolio" class="section-link" data-reveal>View All Portfolio <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== SERVICES (CARDS, MOVED BELOW SHOP) =================== -->
  <section class="section" id="services-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">03 — Services</div>
          <h2>What we can build for you.</h2>
        </div>
        <p class="right">Five disciplines we focus on. Every project gets the same process: slow at the start, quick at the end.</p>
      </div>

      <div class="svc-card-grid">

        <a href="/services#ux" class="svc-tile" data-reveal data-reveal-delay="0">
          <div class="top">
            <span class="num">01</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h18M3 12h12M3 18h7"/></svg>
            </span>
          </div>
          <h3>UX Design</h3>
          <p>Research, wireframing, user flow, and prototyping for products still looking for fit.</p>
        </a>

        <a href="/services#ui" class="svc-tile" data-reveal data-reveal-delay="80">
          <div class="top">
            <span class="num">02</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
            </span>
          </div>
          <h3>UI Design</h3>
          <p>Visual design, design systems, and component libraries that are easy to maintain.</p>
        </a>

        <a href="/services#web" class="svc-tile" data-reveal data-reveal-delay="160">
          <div class="top">
            <span class="num">03</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 14h4"/></svg>
            </span>
          </div>
          <h3>Website Development</h3>
          <p>End-to-end — from company profile to dashboards that need real interactivity.</p>
        </a>

        <a href="/services#landing" class="svc-tile" data-reveal data-reveal-delay="240">
          <div class="top">
            <span class="num">04</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 3h14v18H5z"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
            </span>
          </div>
          <h3>Landing Page</h3>
          <p>A single page that converts — from design to live in 1–2 weeks.</p>
        </a>

        <a href="/services#brand" class="svc-tile" data-reveal data-reveal-delay="320">
          <div class="top">
            <span class="num">05</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg>
            </span>
          </div>
          <h3>Brand &amp; Logo Guideline</h3>
          <p>Logo, brand book, and a visual system ready to hand off to any team.</p>
        </a>

        <a href="/about#contact" class="svc-tile" data-reveal data-reveal-delay="400" style="background:var(--ink); color:var(--cream); border-color:var(--ink);">
          <div class="top">
            <span class="num" style="color:var(--terracotta-soft);">06</span>
            <span class="icon" aria-hidden="true" style="background:transparent; border-color:rgba(246,239,224,.2); color:var(--terracotta-soft);">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
          <h3 style="color:var(--cream);">Something else?</h3>
          <p style="color:var(--cream); opacity:.7;">If what you need isn&rsquo;t on the list, let&rsquo;s talk first. We&rsquo;ll be honest about whether we can help.</p>
        </a>

      </div>
    </div>
  </section>

  <!-- =================== CTA =================== -->
  <section class="section-tight">
    <div class="cta-wrap">
      <div class="cta-panel cta-panel-compact pat-heat">
        <div class="eyebrow">Let&rsquo;s talk</div>
        <h2>Got a project? <em class="italic-accent" style="color:var(--ink)">Let&rsquo;s talk.</em></h2>
        <p>Send us a brief or just tell us your idea. We reply within 1×24 hours (business hours).</p>
        <div class="btn-row">
          <a href="mailto:hello@rohaworks.com" class="btn btn-cream">Email Us <span class="arr">→</span></a>
          <!-- Replace [NO_WA] with active WhatsApp number -->
          <a href="https://wa.me/[NO_WA]?text=Hi%20Roha%2C%20I%27d%20like%20to%20discuss%20a%20project" class="btn btn-outline-cream" target="_blank" rel="noopener">Chat on WhatsApp</a>
        </div>
        <div class="arcs-deco" aria-hidden="true"></div>
      </div>
    </div>
  </section>

</main>
</Base>

