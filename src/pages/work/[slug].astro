---
// src/pages/work/[slug].astro
// Replaces the static work-detail.html.
// Structure & class names mirror the original so work.css applies as-is.

import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CaseTag from '../../components/CaseTag.astro';
import { creativeWorkSchema } from '../../utils/schema';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const entries = (await getCollection('work', ({ data }) => data.visibility !== 'hide' && !data.draft))
    .sort((a, b) => a.data.order - b.data.order);

  return entries.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      // "Next project" = the next item by order, wrapping to the first.
      next: entries[(i + 1) % entries.length],
    },
  }));
}

const { entry, next } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const nextSame = next.id === entry.id; // true only if there is just one entry

// Generate creative work schema
const workSchema = creativeWorkSchema({
  title: d.title,
  summary: d.summary,
  category: d.service || d.category,
  year: d.year,
  image: d.coverImage,
  url: `/work/${entry.id}/`,
  siteUrl: site.url,
});
---

<Base
  title={`${d.title} — Case Study`}
  description={d.summary}
  image={d.coverImage}
  schema={workSchema}
>
  <main id="main">

    {/* HEADER + COVER */}
    <section class="wd-cover">
      <div class="wrap">
        <div class="wd-header">
          <div class="eyebrow">Case Study · {d.year}</div>
          <div class="wd-tag-row">
            <CaseTag concept={d.concept} label={d.tagLabel} tone="light" />
          </div>
          <h1>{d.title}.</h1>
          <p class="section-lede">{d.summary}</p>
          {d.concept && (
            <p class="wd-concept-note">
              Self-initiated concept, not a commissioned project.
            </p>
          )}
        </div>

        {d.coverImage ? (
          <div class="wd-cover-frame wd-cover-image">
            <img src={d.coverImage} alt={`${d.title} — case study cover`} loading="lazy" width={800} height={500} />
          </div>
        ) : (
          <div class={`wd-cover-frame ${d.pattern} pattern-wrap`} aria-hidden="true"></div>
        )}

        <div class="wd-meta-grid">
          <div><div class="k">Year</div><div class="v">{d.year}</div></div>
          <div><div class="k">Client</div><div class="v">{d.client}</div></div>
          <div><div class="k">Duration</div><div class="v">{d.duration}</div></div>
          <div><div class="k">Service</div><div class="v">{d.service}</div></div>
        </div>
      </div>
    </section>

    {/* IMAGES SHOWCASE — if available */}
    {d.images && d.images.length > 0 && (
      <section class="section wd-images-section">
        <div class="wrap">
          <div class="wd-images-grid" id="wdImageGrid">
            {d.images.map((img, i) => (
              <div class="wd-image-item" role="button" tabindex="0" aria-label={`View image ${i + 1}`} data-lb-index={i}>
                <img src={img} alt={`${d.title} — photo ${i + 1}`} loading="lazy" width={600} height={400} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* LIGHTBOX */}
    {d.images && d.images.length > 0 && (
      <div id="lb" class="lb" role="dialog" aria-modal="true" aria-label="Image viewer" tabindex="-1">
        <button id="lb-close" class="lb-close" aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="lb-stage">
          <button id="lb-prev" class="lb-arrow lb-arrow--prev" aria-label="Previous image">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M11 3L5 9l6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="lb-frame">
            <img id="lb-img" class="lb-img" src="" alt="" />
          </div>
          <button id="lb-next" class="lb-arrow lb-arrow--next" aria-label="Next image">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M7 3l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <div class="lb-caption">
          <span id="lb-desc" class="lb-desc"></span>
          <span id="lb-counter" class="lb-counter"></span>
        </div>
      </div>
    )}

    {/* BODY — sections, quote and metrics come from the markdown */}
    <section class="section">
      <div class="wrap">
        <div class="wd-section prose">
          <Content />
        </div>
      </div>
    </section>

    {/* NEXT PROJECT — auto, by order */}
    {!nextSame && (
      <section class="section-tight">
        <div class="cta-wrap">
          <a href={`/work/${next.id}/`} class="wd-next">
            <div>
              <div class="label">Next Project · {next.data.year}</div>
              <h3>{next.data.title}</h3>
            </div>
            <span class="arr" aria-hidden="true">→</span>
          </a>
        </div>
      </section>
    )}

  </main>
</Base>

<script>
(function () {
  var lb = document.getElementById('lb') as HTMLElement | null;
  if (!lb) return;

  var lbImg    = document.getElementById('lb-img')     as HTMLImageElement | null;
  var lbDesc   = document.getElementById('lb-desc')    as HTMLElement | null;
  var lbCounter= document.getElementById('lb-counter') as HTMLElement | null;

  var items = Array.from(document.querySelectorAll<HTMLElement>('#wdImageGrid .wd-image-item'));
  var total = items.length;
  var current = 0;
  var prevFocus: HTMLElement | null = null;

  function show(i: number) {
    current = (i + total) % total;
    var img = items[current].querySelector('img') as HTMLImageElement;
    lbImg!.src = img.src;
    lbImg!.alt = img.alt;
    lbDesc!.textContent = img.alt;
    lbCounter!.textContent = (current + 1) + ' / ' + total;
    // reset scale so transition re-fires on each navigation
    lbImg!.style.transform = 'scale(.96)';
    requestAnimationFrame(function () {
      lbImg!.style.transform = '';
    });
  }

  function open(i: number) {
    prevFocus = document.activeElement as HTMLElement;
    show(i);
    lb!.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    lb!.focus();
  }

  function close() {
    lb!.classList.remove('is-open');
    document.body.style.overflow = '';
    if (prevFocus) prevFocus.focus();
  }

  // Click on image items
  items.forEach(function (item, i) {
    item.addEventListener('click', function () { open(i); });
    item.addEventListener('keydown', function (e) {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        e.preventDefault();
        open(i);
      }
    });
  });

  document.getElementById('lb-close')!.addEventListener('click', close);
  document.getElementById('lb-prev')!.addEventListener('click', function () { show(current - 1); });
  document.getElementById('lb-next')!.addEventListener('click', function () { show(current + 1); });

  // Backdrop click to close
  lb.addEventListener('click', function (e) { if (e.target === lb) close(); });

  // Keyboard navigation
  lb.addEventListener('keydown', function (e) {
    var key = (e as KeyboardEvent).key;
    if (key === 'Escape')      close();
    if (key === 'ArrowLeft')   show(current - 1);
    if (key === 'ArrowRight')  show(current + 1);
  });
})();
</script>
