---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const byDate = (a: any, b: any) => {
  const da = a.data.publishedAt?.getTime() ?? 0;
  const db = b.data.publishedAt?.getTime() ?? 0;
  return db - da;
};

const allWork = await getCollection('work', ({ data }) => !data.draft);
const sortedWork = allWork.sort(byDate).slice(0, 3);

const allPortfolio = await getCollection('portfolio', ({ data }) => !data.draft);
const sortedPortfolio = allPortfolio.sort(byDate).slice(0, 6);
---

<Base
  title="Roha"
  description="Roha is a small studio that helps founders and indie makers build websites, UI/UX, and brands that feel real, not just thrown together."
>
  <main id="main">

  <!-- =================== HERO =================== -->
  <section class="home-hero">
    <div class="wrap">
      <div class="home-hero-grid">

        <div class="home-hero-left">
          <div class="eyebrow">Design Studio · Indonesia</div>
          <h1 class="display">Digital design<br/>made <em class="italic-accent">warm</em>,<br/>shipped tidy.</h1>
          <div class="btn-row">
            <a href="/work" class="btn btn-primary">See Our Work <span class="arr">→</span></a>
            <a href="/about#contact" class="btn btn-secondary">Start a Project</a>
          </div>
          <div class="hero-meta">
            <div class="hero-meta-item">
              <div class="hm-k">UI/UX</div>
              <div class="hm-l">Product Design</div>
            </div>
            <div class="hero-meta-item">
              <div class="hm-k">Web</div>
              <div class="hm-l">Design + Build</div>
            </div>
            <div class="hero-meta-item">
              <div class="hm-k">Brand</div>
              <div class="hm-l">Identity Systems</div>
            </div>
          </div>
        </div>

        <div class="home-hero-right">
          <div class="hero-illus-wrap">
            <!--
              Place hero image at: public/hero.jpg
              Recommended: portrait, min 960×1200px
            -->
            <img src="/hero.jpg" alt="" class="hero-illus" width="480" height="600" loading="eager" />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =================== MARQUEE STRIP =================== -->
  <div class="marquee-strip" aria-hidden="true">
    <div class="marquee-inner">
      <span>Product Design</span><span>Website Development</span><span>Landing Pages</span><span>Brand &amp; Logo</span><span>Design Systems</span><span>Figma Handoff</span>
      <span>Product Design</span><span>Website Development</span><span>Landing Pages</span><span>Brand &amp; Logo</span><span>Design Systems</span><span>Figma Handoff</span>
    </div>
  </div>

  <!-- =================== SERVICES PREVIEW =================== -->
  <section class="section" id="services-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">01 — Services</div>
          <h2>What we can build for you.</h2>
        </div>
        <p class="right">Four disciplines, one clear process. Every project starts slow and ships clean.</p>
      </div>

      <div class="svc-card-grid">

        <a href="/services#product-design" class="svc-tile" data-reveal data-reveal-delay="0">
          <div class="top">
            <span class="num">01</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none">
              <rect x="6" y="12" width="38" height="28" rx="3" stroke="var(--terracotta)" stroke-width="2"/>
              <rect x="6" y="12" width="38" height="8" rx="3" fill="var(--terracotta-soft)"/>
              <rect x="22" y="28" width="36" height="24" rx="3" fill="var(--terracotta)"/>
              <circle cx="40" cy="40" r="6" fill="var(--paper)"/>
              <line x1="12" y1="28" x2="24" y2="28" stroke="var(--terracotta)" stroke-width="2" stroke-linecap="round"/>
              <line x1="12" y1="34" x2="20" y2="34" stroke="var(--terracotta-soft)" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Product Design (UI/UX)</h3>
          <p>Research, wireframing, prototyping, visual design, and a component library, one flow from discovery to developer handoff.</p>
        </a>

        <a href="/services#web" class="svc-tile" data-reveal data-reveal-delay="80">
          <div class="top">
            <span class="num">02</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none">
              <rect x="8" y="10" width="48" height="38" rx="4" stroke="var(--terracotta)" stroke-width="2"/>
              <line x1="8" y1="20" x2="56" y2="20" stroke="var(--terracotta)" stroke-width="2"/>
              <circle cx="14" cy="15" r="1.6" fill="var(--terracotta-soft)"/><circle cx="20" cy="15" r="1.6" fill="var(--terracotta-soft)"/><circle cx="26" cy="15" r="1.6" fill="var(--terracotta-soft)"/>
              <path d="M20 30 L14 35 L20 40" stroke="var(--terracotta)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M36 30 L42 35 L36 40" stroke="var(--terracotta)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="30" y1="28" x2="26" y2="42" stroke="var(--terracotta-soft)" stroke-width="2.4" stroke-linecap="round"/>
              <rect x="22" y="52" width="20" height="4" rx="2" fill="var(--terracotta-soft)"/>
            </svg>
          </div>
          <h3>Website Development</h3>
          <p>End-to-end, from company profile to dashboards that need real interactivity.</p>
        </a>

        <a href="/services#landing" class="svc-tile" data-reveal data-reveal-delay="160">
          <div class="top">
            <span class="num">03</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none">
              <rect x="14" y="6" width="36" height="52" rx="4" stroke="var(--terracotta)" stroke-width="2"/>
              <rect x="20" y="13" width="24" height="14" rx="2" fill="var(--terracotta-soft)"/>
              <line x1="20" y1="34" x2="44" y2="34" stroke="var(--terracotta)" stroke-width="2" stroke-linecap="round"/>
              <line x1="20" y1="40" x2="38" y2="40" stroke="var(--terracotta)" stroke-width="2" stroke-linecap="round"/>
              <rect x="20" y="46" width="16" height="6" rx="3" fill="var(--terracotta)"/>
              <path d="M48 44 L56 40 L52 48 Z" fill="var(--terracotta)"/>
            </svg>
          </div>
          <h3>Landing Page</h3>
          <p>A single page that converts, from design to live in 1&ndash;2 weeks.</p>
        </a>

        <a href="/services#brand" class="svc-tile" data-reveal data-reveal-delay="240">
          <div class="top">
            <span class="num">04</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="20" stroke="var(--terracotta)" stroke-width="2"/>
              <circle cx="32" cy="32" r="9" fill="var(--terracotta-soft)"/>
              <circle cx="32" cy="32" r="3.4" fill="var(--paper)"/>
              <path d="M32 4 V14 M32 50 V60 M4 32 H14 M50 32 H60" stroke="var(--terracotta)" stroke-width="2.4" stroke-linecap="round"/>
              <path d="M12 12 L19 19 M52 12 L45 19 M12 52 L19 45 M52 52 L45 45" stroke="var(--terracotta-soft)" stroke-width="2.4" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Brand &amp; Logo</h3>
          <p>Logo, brand book, and a visual system ready to hand off to any team.</p>
        </a>

        <a href="/about#contact" class="svc-tile svc-tile-dark" data-reveal data-reveal-delay="320">
          <div class="svc-cta-body">
            <div class="top">
              <span class="num" style="color:var(--terracotta-soft);">05</span>
            </div>
            <h3>Something else on your mind?</h3>
            <p>If what you need isn&rsquo;t on the list, let&rsquo;s talk first. We&rsquo;ll be honest about whether we can help.</p>
          </div>
          <div class="svc-cta-circle" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 16 L16 4 M16 4 H6 M16 4 V14" stroke="var(--cream)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </a>

      </div>

      <a href="/services" class="section-link" data-reveal>Full service details &amp; pricing <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== FEATURED WORK =================== -->
  <section class="section case-section" id="work-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">02 — Case Studies</div>
          <h2>Work we&rsquo;ve done.</h2>
        </div>
        <p class="right">Studio projects and concept redesigns. Real process, honest labels.</p>
      </div>

      <div class="featured-scroll-outer">
        <div class="featured-grid">
          {
            sortedWork.map((project, i) => {
              const { title, summary, service, year, pattern, coverImage, concept } = project.data;
              const workLabel = concept ? 'Concept work' : 'Studio project';
              return (
                <a href={`/work/${project.id}`} class="project-card" data-reveal data-reveal-delay={i * 120}>
                  {coverImage ? (
                    <img src={coverImage} alt={title} class="thumb" width={400} height={300} loading="lazy" />
                  ) : (
                    <div class={`thumb ${pattern} pattern-wrap`} aria-hidden="true"></div>
                  )}
                  <div class="project-info">
                    <div class="meta-row">
                      <span class="tag">{service}</span>
                      <span class="year">{year}</span>
                      <span class="work-label">{workLabel}</span>
                    </div>
                    <h3>{title}</h3>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>

      <a href="/work" class="section-link" data-reveal>All Case Studies <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== WHY ROHA =================== -->
  <section class="section">
    <div class="wrap">
      <div class="why-roha-block" data-reveal>
        <div class="eyebrow">Why Roha</div>
        <blockquote class="why-roha-quote">
          Too many founders end up with websites assembled from a template store, technically functional but hollow. Roha exists to close that gap: a one-person studio with a fintech design background, focused on helping small founders build things that feel considered, not just finished.
        </blockquote>
        <p class="why-roha-sub">One designer. Deliberate process. No padding.</p>
      </div>
    </div>
  </section>

  <!-- =================== HOW WE WORK =================== -->
  <section class="section how-section">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">How We Work</div>
          <h2>Four things that guide every project.</h2>
        </div>
        <p class="right">Design that means something, built with intention, from the first call to the final handoff.</p>
      </div>

      <div class="how-grid">
        <div class="how-card" data-reveal>
          <div class="how-illus" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect x="4" y="4" width="13" height="13" rx="2" stroke="var(--terracotta-soft)" stroke-width="2"/>
              <rect x="23" y="4" width="13" height="13" rx="2" stroke="var(--terracotta-soft)" stroke-width="2"/>
              <rect x="4" y="23" width="13" height="13" rx="2" fill="var(--terracotta)"/>
              <rect x="23" y="23" width="13" height="13" rx="2" stroke="var(--terracotta-soft)" stroke-width="2"/>
            </svg>
          </div>
          <h4>Considered at every scale</h4>
          <p>From the smallest button state to the full page system, nothing is left to chance.</p>
        </div>
        <div class="how-card" data-reveal data-reveal-delay="100">
          <div class="how-illus" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <circle cx="20" cy="20" r="9" fill="var(--terracotta)"/>
              <path d="M20 4 V9 M20 31 V36 M4 20 H9 M31 20 H36 M8.5 8.5 L12 12 M31.5 8.5 L28 12 M8.5 31.5 L12 28 M31.5 31.5 L28 28" stroke="var(--terracotta-soft)" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </div>
          <h4>Warmth by design, not default</h4>
          <p>Friendly interfaces don&rsquo;t happen by accident. Warmth is a deliberate craft decision.</p>
        </div>
        <div class="how-card" data-reveal data-reveal-delay="200">
          <div class="how-illus" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <rect x="5" y="5" width="11" height="11" rx="2" fill="var(--terracotta)"/>
              <rect x="24" y="5" width="11" height="11" rx="2" stroke="var(--terracotta-soft)" stroke-width="2"/>
              <rect x="5" y="24" width="11" height="11" rx="2" stroke="var(--terracotta-soft)" stroke-width="2"/>
              <rect x="24" y="24" width="11" height="11" rx="2" fill="var(--terracotta)"/>
              <line x1="16" y1="10.5" x2="24" y2="10.5" stroke="var(--terracotta-soft)" stroke-width="2"/>
              <line x1="10.5" y1="16" x2="10.5" y2="24" stroke="var(--terracotta-soft)" stroke-width="2"/>
            </svg>
          </div>
          <h4>Systems outlast single pages</h4>
          <p>We build reusable systems, so your product keeps its consistency long after launch.</p>
        </div>
        <div class="how-card" data-reveal data-reveal-delay="300">
          <div class="how-illus" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
              <path d="M8 32 L32 8 M32 8 H14 M32 8 V26" stroke="var(--terracotta)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="8" cy="32" r="4" fill="var(--terracotta-soft)"/>
            </svg>
          </div>
          <h4>Ship first, refine after</h4>
          <p>Momentum beats perfection. We get something real live, then sharpen it together.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== TEMPLATES & KITS =================== -->
  <section class="section" id="portfolio-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">03 — Templates &amp; Kits</div>
          <h2>Design kits we&rsquo;ve built.</h2>
        </div>
        <p class="right">Website templates and design kits built as studio work. Proof of craft, ready to adapt.</p>
      </div>

      <div class="shop-grid">
        {
          sortedPortfolio.map((item, i) => {
            const d = item.data;
            const coverImage = d.images?.[0];
            return (
              <a
                href={`/portfolio/${item.id}`}
                class="product-card"
                data-reveal
                data-reveal-delay={i * 100}
                data-preview-url={
                  d.previewPath
                    ? `/templates/${d.previewPath}/index.html`
                    : undefined
                }
                data-preview-title={d.title}
                data-preview-cat={d.category}
              >
                {d.previewPath && (
                  <span
                    class="pv-trigger"
                    role="button"
                    tabindex="0"
                    data-preview-trigger
                    aria-label={`Preview ${d.title}`}
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
                    Preview
                  </span>
                )}
                {coverImage ? (
                  <div class="cover">
                    <img src={coverImage} alt={d.title} width={350} height={280} loading="lazy" />
                  </div>
                ) : (
                  <div class={`cover ${d.pattern} pattern-wrap`} aria-hidden="true"></div>
                )}
                <div class="body">
                  <span class="cat">{d.category}</span>
                  <div class="name-row">
                    <h3 class="name">{d.title}</h3>
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>

      <a href="/portfolio" class="section-link" data-reveal>View All Templates <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== CTA =================== -->
  <section class="section-tight">
    <div class="cta-wrap">
      <div class="cta-panel cta-panel-compact pat-heat">
        <div class="eyebrow">Let&rsquo;s talk</div>
        <h2>Got a project? <em class="italic-accent" style="color:var(--ink)">Let&rsquo;s talk.</em></h2>
        <p>Send us a brief or just tell us your idea. We reply within 1&times;24 hours (business hours).</p>
        <div class="btn-row">
          <a href="mailto:halo@roha.design" class="btn btn-cream">Email Us <span class="arr">→</span></a>
          <a href="/about#contact" class="btn btn-outline-cream">Contact Page</a>
        </div>
        <div class="arcs-deco" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!--
    TESTIMONIALS — removed until real client testimonials are available.
    Re-add this section with verified quotes before publishing to clients.
  -->

</main>
</Base>
