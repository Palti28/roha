---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const portfolio = (await getCollection('portfolio', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Roha"
  description="Roha is a design studio building websites, UI/UX, and brand systems that are considered, durable, and ready to ship."
>
  <main id="main">

    <!-- =================== HERO =================== -->
    <section class="home-hero">
      <div class="wrap">
        <div class="home-hero-grid">

          <div class="home-hero-left">
            <div class="eyebrow">DESIGN STUDIO &middot; INDONESIA</div>
            <h1 class="display">The right place<br />to build your<br /><em class="italic-accent">next idea.</em></h1>
            <p class="hero-sub">We design and build websites, landing pages, and brand identities for founders who want something considered, not just something quick.</p>
            <div class="btn-row">
              <a href="/about#contact" class="btn btn-primary">Start a Project <span class="arr">→</span></a>
              <a href="/portfolio" class="btn btn-secondary">See Our Work</a>
            </div>
            <div class="hero-meta">
              <div class="hero-meta-item">
                <div class="hm-k">UI/UX</div>
                <div class="hm-l">Product Design</div>
              </div>
              <div class="hero-meta-item">
                <div class="hm-k">Web</div>
                <div class="hm-l">Design + Build</div>
              </div>
              <div class="hero-meta-item">
                <div class="hm-k">Brand</div>
                <div class="hm-l">Identity Systems</div>
              </div>
            </div>
          </div>

          <div class="home-hero-right">
            <div class="hero-illus-wrap">
              <img src="/hero-illustration.svg" class="hero-illus" alt="Ilustrasi alat desain dan pengembangan web" width="491" height="423" loading="eager" decoding="async" />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- =================== STATS STRIP =================== -->
    <div class="studio-strip">
      <div class="wrap">
        <dl class="studio-stats">
          <div class="stat-item">
            <dt>2021</dt>
            <dd>STUDIO FOUNDED</dd>
          </div>
          <div class="stat-item">
            <dt>UI/UX &middot; WEB &middot; BRAND</dt>
            <dd>CORE DISCIPLINES</dd>
          </div>
          <div class="stat-item">
            <dt>1&ndash;2 WEEKS</dt>
            <dd>TYPICAL TURNAROUND</dd>
          </div>
          <div class="stat-item">
            <dt>INDONESIA</dt>
            <dd>BASED IN</dd>
          </div>
        </dl>
      </div>
    </div>

    <!-- =================== MAIN NAV (sticky trigger) =================== -->
    <Nav />

    <!-- =================== WORK GRID =================== -->
    <section class="lp-work">
      <div class="lp-work-inner">
        <div class="lp-work-head">
          <div class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>Work</div>
          <div class="lp-work-head-row">
            <h2 class="lp-work-title">Selected Work</h2>
            <a href="/portfolio" class="btn btn-primary lp-work-all">View All Work <span class="arr">→</span></a>
          </div>
        </div>

        <div class="lp-grid">
          {
            portfolio.map((item) => {
              const d = item.data;
              const cover = d.images?.[0];
              const initial = d.title.trim().charAt(0).toUpperCase();
              return (
                <a href={`/portfolio/${item.id}`} class="lp-tile">
                  <div class="lp-thumb">
                    <span class="lp-tag">{d.category}</span>
                    {cover ? (
                      <img src={cover} alt={d.title} width="400" height="400" loading="lazy" />
                    ) : (
                      <div class="lp-thumb-fallback" aria-hidden="true"><span>{initial}</span></div>
                    )}
                  </div>
                  <div class="lp-tile-body">
                    <p class="lp-tile-desc"><span class="lp-tile-name">{d.title}.</span> {d.tagline}</p>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- =================== CTA BANNER (dark) =================== -->
    <section class="lp-cta-wrap">
      <div class="lp-cta-inner">
        <div class="lp-cta-panel lp-cta-dark">
          <div class="lp-cta-body">
            <p class="lp-cta-eyebrow">LET&rsquo;S TALK</p>
            <h2 class="lp-cta-title">Got a project? <em class="italic-accent lp-cta-em">Let&rsquo;s talk.</em></h2>
            <p class="lp-cta-sub">Send us a brief or just tell us your idea. We reply within 1&times;24 hours (business hours).</p>
          </div>
          <div class="lp-cta-actions">
            <a href="/about#contact" class="lp-btn-terra">Start a Project <span class="arr">→</span></a>
            <a href="mailto:hello@rohaworks.com" class="lp-btn-ghost">Email Us</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <script>
  (function () {
    const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    // ── 1. Hero entrance — staggered fade + slide up ──
    [
      { q: '.home-hero-left .eyebrow',   delay: 60  },
      { q: '.home-hero-left h1',         delay: 160 },
      { q: '.home-hero-left .hero-sub',  delay: 260 },
      { q: '.home-hero-left .btn-row',   delay: 340 },
      { q: '.home-hero-left .hero-meta', delay: 440 },
      { q: '.home-hero-right',           delay: 180 },
    ].forEach(({ q, delay }) => {
      const el = document.querySelector(q);
      if (el) setTimeout(() => el.classList.add('is-visible'), delay);
    });

    // ── 2. Hero illustration cursor parallax ──
    const heroSec = document.querySelector('.home-hero') as HTMLElement | null;
    const illusWrap = document.querySelector('.hero-illus-wrap') as HTMLElement | null;
    if (heroSec && illusWrap && canHover) {
      heroSec.addEventListener('mousemove', (e) => {
        const r = heroSec.getBoundingClientRect();
        const x = (e.clientX - r.left - r.width / 2) / r.width;
        const y = (e.clientY - r.top - r.height / 2) / r.height;
        illusWrap.style.transform = `translate(${x * -14}px,${y * -8}px)`;
      });
      heroSec.addEventListener('mouseleave', () => { illusWrap.style.transform = ''; });
    }

    // ── 3. Work tiles — stagger reveal on scroll ──
    const tiles = document.querySelectorAll('.lp-tile');
    if ('IntersectionObserver' in window && tiles.length) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.07, rootMargin: '0px 0px -28px 0px' }
      );
      tiles.forEach((tile, i) => {
        (tile as HTMLElement).style.transitionDelay = `${i * 55}ms`;
        io.observe(tile);
      });
    }

    // ── 4. Work card — cursor-following shadow (no 3D transform, avoids border-radius glitch) ──
    if (canHover) {
      document.querySelectorAll<HTMLElement>('.lp-tile').forEach((card) => {
        const thumb = card.querySelector<HTMLElement>('.lp-thumb');
        if (!thumb) return;
        card.addEventListener('mousemove', (e) => {
          const r = thumb.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width - 0.5;
          const y = (e.clientY - r.top) / r.height - 0.5;
          thumb.style.boxShadow = `${x * -14}px ${y * -10}px 32px rgba(0,0,0,.13), 0 2px 8px rgba(0,0,0,.06)`;
        });
        card.addEventListener('mouseleave', () => { thumb.style.boxShadow = ''; });
      });
    }

    // ── 5. Magnetic CTA primary button ──
    const ctaBtn = document.querySelector<HTMLElement>('.lp-btn-terra');
    if (ctaBtn && canHover) {
      const RANGE = 110;
      document.addEventListener('mousemove', (e) => {
        const r = ctaBtn.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        ctaBtn.style.transform = dist < RANGE
          ? `translate(${dx * (1 - dist / RANGE) * 0.35}px,${dy * (1 - dist / RANGE) * 0.35}px)`
          : '';
      });
    }

    // ── 6. Stats strip — count-up for numeric values ──
    const statDts = document.querySelectorAll<HTMLElement>('.stat-item dt');
    const countIO = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const raw = el.textContent?.trim() ?? '';
        const num = parseInt(raw.replace(/\D/g, ''), 10);
        if (isNaN(num)) { countIO.unobserve(el); return; }
        const dur = 900;
        const start = performance.now();
        const from = Math.max(0, num - Math.min(num, 80));
        const tick = (now: number) => {
          const t = Math.min((now - start) / dur, 1);
          const ease = 1 - Math.pow(1 - t, 3);
          el.textContent = String(Math.round(from + (num - from) * ease));
          if (t < 1) requestAnimationFrame(tick);
          else el.textContent = raw;
        };
        requestAnimationFrame(tick);
        countIO.unobserve(el);
      });
    }, { threshold: 0.5 });
    statDts.forEach((dt) => countIO.observe(dt));
  })();
  </script>
</Base>
