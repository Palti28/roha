                <rect width="900" height="220" fill="#1a1611"/>
                <line x1="210" y1="0" x2="210" y2="220" stroke="white" stroke-opacity=".07" stroke-width="1"/>
                <line x1="662" y1="0" x2="662" y2="220" stroke="white" stroke-opacity=".07" stroke-width="1"/>
                <!-- layers panel -->
                <text x="16" y="20" font-family="monospace" font-size="7" letter-spacing=".14em" fill="white" fill-opacity=".25">LAYERS</text>
