              <rect x="100" y="57" width="128" height="9" rx="4.5" fill="var(--ink)" opacity="0.13"/>
              <rect x="100" y="72" width="84" height="7" rx="3.5" fill="var(--ink)" opacity="0.09"/>
              <rect x="250" y="54" width="56" height="22" rx="5" stroke="var(--ink)" stroke-width="1" fill="none" opacity="0.18"/>
              <line x1="263" y1="65" x2="293" y2="65" stroke="var(--ink)" stroke-width="1" stroke-linecap="round" opacity="0.18"/>

              <!-- SCOPE section -->
              <text x="100" y="103" font-family="'Geist Mono', monospace" font-size="6.5" fill="var(--ink)" letter-spacing=".16em" opacity="0.38">SCOPE</text>
              <rect x="100" y="110" width="172" height="7" rx="3.5" fill="var(--ink)" opacity="0.09"/>
              <rect x="100" y="123" width="138" height="7" rx="3.5" fill="var(--ink)" opacity="0.09"/>
              <rect x="100" y="136" width="158" height="7" rx="3.5" fill="var(--ink)" opacity="0.09"/>
              <line x1="84" y1="158" x2="326" y2="158" stroke="var(--rule)" stroke-width="1"/>

              <!-- DELIVERABLES section -->
              <text x="100" y="176" font-family="'Geist Mono', monospace" font-size="6.5" fill="var(--ink)" letter-spacing=".16em" opacity="0.38">DELIVERABLES</text>
