---
const navLinks = [
  { href: '/portfolio', label: 'Work' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Case Studies' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<!-- =================== TOPBAR =================== -->
<header class="topbar" role="banner">
  <div class="topbar-inner">
    <a href="/" class="logo" aria-label="Roha — Home">roha<span class="dot">.</span></a>
    <span class="topbar-url">rohaworks.com</span>
    <button class="topbar-burger" id="topbarBurger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="topbarMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="topbar-menu" id="topbarMenu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="topbar-menu-links">
        {navLinks.map((link, i) => (
          <li style={`--i: ${i}`}>
            <a href={link.href} class={isActive(link.href) ? 'active' : ''}>
              <span class="tml-label">{link.label}</span>
              <span class="tml-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="topbar-menu-footer">
        <a href="/about#contact" class="tmf-cta">Start a Project →</a>
        <span class="tmf-tagline">Considered design, built to last.</span>
      </div>
    </nav>
  </div>
</header>

<script>
(function () {
  const burger = document.getElementById('topbarBurger') as HTMLButtonElement | null;
  const menu   = document.getElementById('topbarMenu')   as HTMLElement | null;
  if (!burger || !menu) return;

  function open() {
    menu.classList.add('is-open');
    burger.setAttribute('aria-expanded', 'true');
    burger.setAttribute('aria-label', 'Close navigation menu');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    menu.classList.remove('is-open');
    burger.setAttribute('aria-expanded', 'false');
    burger.setAttribute('aria-label', 'Open navigation menu');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', function () {
    menu.classList.contains('is-open') ? close() : open();
  });

  menu.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', close);
  });

  // Close on Escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && menu.classList.contains('is-open')) close();
  });
})();
</script>
