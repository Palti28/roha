                <rect x="48" y="104" width="36" height="7" rx="2" fill="#c1440e" fill-opacity=".5"/>
                <rect x="90" y="104" width="60" height="7" rx="2" fill="white" fill-opacity=".22"/>
                <!-- highlighted active line -->
