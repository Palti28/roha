---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";

const portfolio = (
  await getCollection("portfolio", ({ data }) => !data.draft)
).sort((a, b) => a.data.order - b.data.order);

const filterMap: Record<string, string> = {
  "UI Kit": "ui",
  "Website Template": "web",
  "Figma Template": "figma",
  "Brand Template": "brand",
};
---

<Base
  title="Portfolio"
  description="Roha Design portfolio: design templates, UI kits, and digital products we've created. Explore our work and design examples."
>
  <Nav />
  <main id="main">
    <!-- HERO -->
    <section class="shop-hero">
      <div class="wrap">
        <div class="eyebrow">Portfolio</div>
        <h1 data-reveal>Design systems, templates,<br />and digital work.</h1>
        <p class="section-lede" data-reveal data-reveal-delay="100">
          Explore the design templates, UI kits, and digital products we&rsquo;ve created. Examples of our approach to thoughtful, systematic design.
        </p>

        <div class="shop-filters pills" data-shop-filter>
          <button class="pill active" data-filter="all">All</button>
          <button class="pill" data-filter="ui">UI Kit</button>
          <button class="pill" data-filter="web">Website Template</button>
          <button class="pill" data-filter="figma">Figma Template</button>
          <button class="pill" data-filter="brand">Brand Template</button>
          <button class="pill" data-filter="other">Other</button>
        </div>
      </div>
    </section>

    <!-- GRID -->
    <section class="section-tight">
      <div class="wrap">
        <div class="lp-grid" data-shop-grid>
          {
            portfolio.map((p, i) => {
              const d = p.data;
              const coverImage = d.images?.[0];
              const filterVal = filterMap[d.category] ?? "other";
              const initial = d.title.trim().charAt(0).toUpperCase();

              return (
                <a
                  href={`/portfolio/${p.id}/`}
                  class="lp-tile"
                  data-category={filterVal}
                  data-reveal
                  data-reveal-delay={i * 80}
                  data-preview-url={d.previewPath ? `templates/${d.previewPath}/index.html` : undefined}
                  data-preview-title={d.title}
                  data-preview-cat={d.category}
                  data-preview-detail={`/portfolio/${p.id}/`}
                >
                  <div class="lp-thumb">
                    <span class="lp-tag">{d.category}</span>
                    {d.previewPath && (
                      <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label={`Preview ${d.title}`}>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                          <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z" />
                          <circle cx="12" cy="12" r="3" />
                        </svg>
                        Preview
                      </span>
                    )}
                    {coverImage ? (
                      <img src={coverImage} alt={d.title} width={350} height={280} loading="lazy" />
                    ) : (
                      <div class="lp-thumb-fallback" aria-hidden="true"><span>{initial}</span></div>
                    )}
                  </div>
                  <div class="lp-tile-body">
                    <p class="lp-tile-desc"><span class="lp-tile-name">{d.title}.</span> {d.tagline}</p>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- APPROACH -->
    <section class="section">
      <div class="wrap">
        <div class="h-block">
          <div class="left">
            <div class="eyebrow">Our Work Philosophy</div>
            <h2>How we approach design systems and digital products.</h2>
          </div>
          <p class="right">
            Every template here was built for real use, refined through real project work. Systematic, thoughtful, and ready to adapt.
          </p>
        </div>

        <div class="why-grid">
          <div class="why-card">
            <span class="icon" aria-hidden="true"
              ><svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                ><rect x="3" y="3" width="18" height="18" rx="3"></rect><path
                  d="M3 9h18M9 3v18"></path></svg
              ></span
            >
            <h3>Systematic design</h3>
            <p>Built on tokens, components, and reusable patterns, not ad hoc one-offs.</p>
          </div>
          <div class="why-card">
            <span class="icon" aria-hidden="true"
              ><svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                ><path d="M3 7l9-4 9 4-9 4-9-4zM3 12l9 4 9-4M3 17l9 4 9-4"
                ></path></svg
              ></span
            >
            <h3>Production-ready</h3>
            <p>Used on real projects. Refined, tested, and documented for actual use.</p>
          </div>
          <div class="why-card">
            <span class="icon" aria-hidden="true"
              ><svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                ><path d="M14 3H6a2 2 0 00-2 2v14a2 2 0 002 2h12a2 2 0 002-2V9z"
                ></path><path d="M14 3v6h6"></path><path d="M9 13h6M9 17h4"
                ></path></svg
              ></span
            >
            <h3>Well-documented</h3>
            <p>
              Structure explained, best practices included, ready to extend or customize for your needs.
            </p>
          </div>
          <div class="why-card">
            <span class="icon" aria-hidden="true"
              ><svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                ><path d="M21 12a9 9 0 11-3-6.7L21 8"></path><path
                  d="M21 3v5h-5"></path></svg
              ></span
            >
            <h3>Roha's actual work</h3>
            <p>
              Not templates made to sell. These are the systems and approaches we use in our own work.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section" id="faq">
      <div class="wrap">
        <div class="h-block">
          <div class="left">
            <div class="eyebrow">Portfolio FAQ</div>
            <h2>Common questions.</h2>
          </div>
        </div>

        <div style="max-width:560px;">
          <div class="accordion">
            <div class="accordion-item">
              <button class="accordion-trigger"
                >What file formats are included? <span class="icon">+</span
                ></button
              >
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Mostly Figma (.fig). Some portfolio items also include Framer, Webflow, or code (React/Astro) versions. Per-item details are on each portfolio page.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger"
                >Can I use these in my own work? <span class="icon">+</span
                ></button
              >
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Yes. These portfolio pieces come with a personal &amp; commercial license, usable for personal projects, client work, and on products you create. What&rsquo;s not allowed: reselling the raw file itself without modification.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger"
                >Can I customize or modify these? <span class="icon">+</span
                ></button
              >
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Absolutely. These are designed to be adapted. Use them as starting points for your own work. If you need custom design work built from scratch, we&rsquo;re happy to discuss that separately.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger"
                >Is there documentation? <span class="icon">+</span></button
              >
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Yes. Each portfolio item includes documentation covering the structure, how to use it, and best practices for extending it.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger"
                >Are these actively maintained? <span class="icon">+</span></button
              >
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Yes. We update these as our approach evolves and as tools improve. Updates are shared with anyone who uses them.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-tight">
      <div class="cta-wrap">
        <div class="cta-panel cta-panel-compact pat-heat">
          <div class="eyebrow">Let&rsquo;s Work Together</div>
          <h2>
            Need a custom <em
              class="italic-accent"
              style="color:var(--ink)">design solution</em
            >?
          </h2>
          <p>
            These portfolio pieces show our approach. If you need custom design, branding, or development work, let&rsquo;s talk.
          </p>
          <div class="btn-row">
            <a href="/about#contact" class="btn btn-cream"
              >Start a Project <span class="arr">→</span></a
            >
            <a href="mailto:hello@rohaworks.com" class="btn btn-outline-cream"
              >Email Us</a
            >
          </div>
          <div class="arcs-deco" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  </main>
</Base>
