---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const portfolio = (await getCollection('portfolio', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Roha"
  description="Roha is a design studio building websites, UI/UX, and brand systems that are considered, durable, and ready to ship."
>
  <main id="main">

    <!-- =================== HERO =================== -->
    <section class="lp-hero">
      <div class="lp-hero-inner">
        <div class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>Digital Design Studio &middot; Indonesia</div>
        <h1 class="lp-hero-title">The right place<br />to build your<br /><em class="italic-accent">next idea.</em></h1>
        <p class="lp-hero-tagline">We design and build websites, landing pages, and brand identities for founders who want something considered, not just something quick.</p>
        <dl class="lp-stats">
          <div class="lp-stat">
            <dt>2021</dt>
            <dd>Founded</dd>
          </div>
          <div class="lp-stat">
            <dt>UI/UX &middot; Web &middot; Brand</dt>
            <dd>Disciplines</dd>
          </div>
          <div class="lp-stat">
            <dt>1&ndash;2 wk</dt>
            <dd>Turnaround</dd>
          </div>
          <div class="lp-stat">
            <dt>Indonesia</dt>
            <dd>Based in</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- =================== MAIN NAV (sticky trigger) =================== -->
    <Nav />

    <!-- =================== WORK GRID =================== -->
    <section class="lp-work">
      <div class="lp-work-inner">
        <div class="lp-work-head">
          <div class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>Selected Work</div>
          <h2 class="lp-work-title">Projects &amp; Case Studies</h2>
        </div>

        <div class="lp-grid">
          {
            portfolio.map((item) => {
              const d = item.data;
              const cover = d.images?.[0];
              const initial = d.title.trim().charAt(0).toUpperCase();
              return (
                <a href={`/portfolio/${item.id}`} class="lp-tile">
                  <div class="lp-thumb">
                    <span class="lp-tag">{d.category}</span>
                    {cover ? (
                      <img src={cover} alt={d.title} width="400" height="400" loading="lazy" />
                    ) : (
                      <div class="lp-thumb-fallback" aria-hidden="true"><span>{initial}</span></div>
                    )}
                  </div>
                  <div class="lp-tile-body">
                    <p class="lp-tile-desc"><span class="lp-tile-name">{d.title}.</span> {d.tagline}</p>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- =================== CTA BANNER =================== -->
    <section class="lp-cta-wrap">
      <div class="lp-cta-inner">
        <div class="lp-cta-panel">
          <div class="lp-cta-body">
            <div class="eyebrow" style="color:var(--cream);opacity:.75;">LET&rsquo;S TALK</div>
            <h2 class="lp-cta-title">Got a project? <em class="italic-accent" style="color:var(--cream)">Let&rsquo;s talk.</em></h2>
            <p class="lp-cta-sub">Send us a brief or just tell us your idea. We reply within 1&times;24 hours (business hours).</p>
          </div>
          <div class="lp-cta-actions">
            <a href="/about#contact" class="btn lp-btn-cream">Start a Project <span class="arr">→</span></a>
            <a href="mailto:hello@rohaworks.com" class="btn lp-btn-outline">Email Us</a>
          </div>
        </div>
      </div>
    </section>

  </main>
</Base>
