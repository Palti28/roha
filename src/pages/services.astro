            </div>
            <div class="deliverables">
              <h4>Includes</h4>
              <ul>
                <li>Figma file</li>
                <li>3 basic user journeys / user flows</li>
                <li>UI/UX design</li>
                <li>Simple prototype</li>
                <li>Raw design data</li>
                <li><em>Extras beyond basic scope → quoted separately</em></li>
              </ul>
            </div>
            <div class="cta-col">
              <a href="/about#contact" class="btn btn-secondary">Get a quote <span class="arr">→</span></a>
            </div>
          </article>

          <!-- 02 Web -->
          <article class="svc-card" id="web" data-reveal data-reveal-delay="100">
