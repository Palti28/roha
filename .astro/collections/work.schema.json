{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "web",
        "uiux",
        "branding"
      ]
    },
    "service": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "year": {
      "type": "number"
    },
    "client": {
      "type": "string"
    },
    "concept": {
      "default": false,
      "type": "boolean"
    },
    "cover": {
      "type": "string"
    },
    "previewPath": {
      "type": "string"
    },
    "pattern": {
      "default": "pat-arcs",
      "type": "string"
    },
    "order": {
      "default": 0,
      "type": "number"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "summary",
    "category",
    "service",
    "duration",
    "year",
    "client"
  ]
}