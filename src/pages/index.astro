---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const byDate = (a: any, b: any) => {
  const da = a.data.publishedAt?.getTime() ?? 0;
  const db = b.data.publishedAt?.getTime() ?? 0;
  return db - da;
};

const allWork = await getCollection('work', ({ data }) => !data.draft);
const sortedWork = allWork.sort(byDate).slice(0, 3);

const allPortfolio = await getCollection('portfolio', ({ data }) => !data.draft);
const sortedPortfolio = allPortfolio.sort(byDate).slice(0, 6);
---

<Base
  title="Roha"
  description="Roha is a small studio that helps founders and indie makers build websites, UI/UX, and brands that feel real, not just thrown together."
>
  <main id="main">

  <!-- =================== HERO =================== -->
  <section class="home-hero">
    <div class="wrap">
      <div class="home-hero-grid">

        <div class="home-hero-left">
          <div class="eyebrow">Design Studio</div>
          <h1 class="display">Digital design<br/>made <em class="italic-accent">warm</em>,<br/>shipped tidy.</h1>
          <p class="hero-sub">Roha is a small studio that helps founders and indie makers build websites, UI/UX, and brands that feel real, not just thrown together.</p>
          <div class="hero-tags" aria-hidden="true">
            <span>UI/UX</span>
            <span>Web</span>
            <span>Brand</span>
          </div>
          <div class="btn-row">
            <a href="/work" class="btn btn-primary">See Our Work <span class="arr">→</span></a>
            <a href="/about#contact" class="btn btn-secondary">Start a Project</a>
          </div>
        </div>

        <div class="home-hero-right">
          <div class="hero-illus-wrap">
            <!--
              Place hero image at: public/hero.jpg
              Recommended: portrait, min 960×1200px
            -->
            <img src="/hero.jpg" alt="" class="hero-illus" width="480" height="600" loading="eager" />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =================== SERVICES PREVIEW =================== -->
  <section class="section" id="services-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">01 — Services</div>
          <h2>What we can build for you.</h2>
        </div>
        <p class="right">Four disciplines, one clear process. Every project starts slow and ships clean.</p>
      </div>

      <div class="svc-card-grid">

        <a href="/services#product-design" class="svc-tile" data-reveal data-reveal-delay="0">
          <div class="top">
            <span class="num">01</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <rect x="8" y="10" width="36" height="28" rx="3"/>
              <line x1="8" y1="18" x2="44" y2="18"/>
              <line x1="14" y1="24" x2="30" y2="24" opacity=".4"/>
              <line x1="14" y1="29" x2="24" y2="29" opacity=".4"/>
              <circle cx="50" cy="46" r="9"/>
              <line x1="50" y1="41" x2="50" y2="51"/>
              <line x1="45" y1="46" x2="55" y2="46"/>
              <path d="M30 44 L38 40" stroke-dasharray="2 2" opacity=".4"/>
              <circle cx="28" cy="45" r="2.5" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <h3>Product Design (UI/UX)</h3>
          <p>Research, wireframing, prototyping, visual design, and a component library, one flow from discovery to developer handoff.</p>
        </a>

        <a href="/services#web" class="svc-tile" data-reveal data-reveal-delay="80">
          <div class="top">
            <span class="num">02</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <rect x="6" y="12" width="52" height="36" rx="3"/>
              <line x1="6" y1="20" x2="58" y2="20"/>
              <circle cx="13" cy="16" r="1.8" fill="currentColor" stroke="none"/>
              <circle cx="19" cy="16" r="1.8" fill="currentColor" stroke="none"/>
              <circle cx="25" cy="16" r="1.8" fill="currentColor" stroke="none"/>
              <path d="M16 30 L22 36 L16 42" opacity=".55"/>
              <line x1="26" y1="42" x2="34" y2="42" opacity=".55"/>
              <line x1="38" y1="28" x2="50" y2="28" opacity=".35"/>
              <line x1="38" y1="33" x2="46" y2="33" opacity=".35"/>
              <line x1="38" y1="38" x2="48" y2="38" opacity=".35"/>
            </svg>
          </div>
          <h3>Website Development</h3>
          <p>End-to-end, from company profile to dashboards that need real interactivity.</p>
        </a>

        <a href="/services#landing" class="svc-tile" data-reveal data-reveal-delay="160">
          <div class="top">
            <span class="num">03</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <rect x="14" y="6" width="36" height="46" rx="2.5"/>
              <line x1="20" y1="16" x2="44" y2="16" opacity=".4"/>
              <rect x="20" y="20" width="24" height="10" rx="1.5" opacity=".3"/>
              <line x1="20" y1="35" x2="38" y2="35" opacity=".4"/>
              <line x1="20" y1="40" x2="32" y2="40" opacity=".4"/>
              <path d="M36 48 L48 36"/>
              <path d="M42 36 L48 36 L48 42"/>
            </svg>
          </div>
          <h3>Landing Page</h3>
          <p>A single page that converts, from design to live in 1&ndash;2 weeks.</p>
        </a>

        <a href="/services#brand" class="svc-tile" data-reveal data-reveal-delay="240">
          <div class="top">
            <span class="num">04</span>
          </div>
          <div class="svc-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <circle cx="32" cy="32" r="20"/>
              <circle cx="32" cy="32" r="8"/>
              <circle cx="32" cy="32" r="2.5" fill="currentColor" stroke="none"/>
              <line x1="32" y1="12" x2="32" y2="24" opacity=".4"/>
              <line x1="32" y1="40" x2="32" y2="52" opacity=".4"/>
              <line x1="12" y1="32" x2="24" y2="32" opacity=".4"/>
              <line x1="40" y1="32" x2="52" y2="32" opacity=".4"/>
            </svg>
          </div>
          <h3>Brand &amp; Logo</h3>
          <p>Logo, brand book, and a visual system ready to hand off to any team.</p>
        </a>

        <a href="/about#contact" class="svc-tile svc-tile-dark" data-reveal data-reveal-delay="320">
          <div class="svc-cta-body">
            <div class="top">
              <span class="num" style="color:var(--terracotta-soft);">05</span>
            </div>
            <h3>Something else?</h3>
            <p>If what you need isn&rsquo;t on the list, let&rsquo;s talk first. We&rsquo;ll be honest about whether we can help.</p>
          </div>
          <span class="svc-cta-arr" aria-hidden="true">→</span>
        </a>

      </div>

      <a href="/services" class="section-link" data-reveal>Full service details &amp; pricing <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== FEATURED WORK =================== -->
  <section class="section" id="work-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">02 — Case Studies</div>
          <h2>Work we&rsquo;ve done.</h2>
        </div>
        <p class="right">Studio projects and concept redesigns. Real process, honest labels.</p>
      </div>

      <div class="featured-scroll-outer">
        <div class="featured-grid">
          {
            sortedWork.map((project, i) => {
              const { title, summary, service, year, pattern, coverImage, concept } = project.data;
              const workLabel = concept ? 'Concept work' : 'Studio project';
              return (
                <a href={`/work/${project.id}`} class="project-card" data-reveal data-reveal-delay={i * 120}>
                  {coverImage ? (
                    <img src={coverImage} alt={title} class="thumb" width={400} height={300} loading="lazy" />
                  ) : (
                    <div class={`thumb ${pattern} pattern-wrap`} aria-hidden="true"></div>
                  )}
                  <div class="meta-row">
                    <span class="tag">{service}</span>
                    <span class="year">{year}</span>
                    <span class="work-label">{workLabel}</span>
                  </div>
                  <h3>{title}</h3>
                </a>
              );
            })
          }
        </div>
      </div>

      <a href="/work" class="section-link" data-reveal>All Case Studies <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== WHY ROHA =================== -->
  <section class="section">
    <div class="wrap">
      <div class="why-roha-block" data-reveal>
        <div class="eyebrow">Why Roha</div>
        <blockquote class="why-roha-quote">
          Too many founders end up with websites assembled from a template store, technically functional but hollow. Roha exists to close that gap: a one-person studio with a fintech design background, focused on helping small founders build things that feel considered, not just finished.
        </blockquote>
        <p class="why-roha-sub">One designer. Deliberate process. No padding.</p>
      </div>
    </div>
  </section>

  <!-- =================== HOW WE WORK =================== -->
  <section class="section">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">How We Work</div>
          <h2>Four things that guide every project.</h2>
        </div>
        <p class="right">Design that means something, built with intention.</p>
      </div>

      <div class="principles-grid">
        <div class="principle" data-reveal>
          <div class="principle-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <line x1="8" y1="16" x2="56" y2="16"/>
              <line x1="14" y1="23" x2="50" y2="23"/>
              <line x1="4" y1="31" x2="60" y2="31" stroke-dasharray="2 2.5" opacity=".3"/>
              <rect x="9" y="37" width="13" height="9" rx="2"/>
              <rect x="25.5" y="37" width="13" height="9" rx="2"/>
              <rect x="42" y="37" width="13" height="9" rx="2"/>
              <rect x="17" y="51" width="13" height="9" rx="2" opacity=".45"/>
              <rect x="34" y="51" width="13" height="9" rx="2" opacity=".45"/>
              <path d="M15.5 46 L23.5 51" opacity=".5"/>
              <path d="M31 46 L23.5 51" opacity=".5"/>
              <path d="M31 46 L40.5 51" opacity=".5"/>
              <path d="M48.5 46 L40.5 51" opacity=".5"/>
            </svg>
          </div>
          <span class="principle-num">01</span>
          <h4>Scale intentionally.</h4>
          <p>Every detail gets the same attention, from a single button to the full user flow.</p>
        </div>
        <div class="principle" data-reveal data-reveal-delay="100">
          <div class="principle-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <circle cx="32" cy="32" r="18"/>
              <circle cx="32" cy="32" r="7"/>
              <line x1="32" y1="6" x2="32" y2="12"/>
              <line x1="32" y1="52" x2="32" y2="58"/>
              <line x1="6" y1="32" x2="12" y2="32"/>
              <line x1="52" y1="32" x2="58" y2="32"/>
              <line x1="13.8" y1="13.8" x2="18.1" y2="18.1"/>
              <line x1="45.9" y1="45.9" x2="50.2" y2="50.2"/>
              <line x1="50.2" y1="13.8" x2="45.9" y2="18.1"/>
              <line x1="18.1" y1="45.9" x2="13.8" y2="50.2"/>
              <circle cx="32" cy="32" r="2.5" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <span class="principle-num">02</span>
          <h4>Warmth by design.</h4>
          <p>Character comes from deliberate choices, not defaults or template presets.</p>
        </div>
        <div class="principle" data-reveal data-reveal-delay="200">
          <div class="principle-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <rect x="7" y="7" width="20" height="14" rx="2.5"/>
              <rect x="37" y="7" width="20" height="14" rx="2.5"/>
              <rect x="7" y="43" width="20" height="14" rx="2.5"/>
              <rect x="37" y="43" width="20" height="14" rx="2.5"/>
              <circle cx="32" cy="32" r="5"/>
              <line x1="27" y1="21" x2="29.5" y2="27"/>
              <line x1="37" y1="21" x2="34.5" y2="27"/>
              <line x1="27" y1="43" x2="29.5" y2="37"/>
              <line x1="37" y1="43" x2="34.5" y2="37"/>
              <line x1="11" y1="12" x2="22" y2="12" opacity=".35"/>
              <line x1="11" y1="16" x2="18" y2="16" opacity=".35"/>
              <line x1="41" y1="12" x2="52" y2="12" opacity=".35"/>
              <line x1="41" y1="16" x2="48" y2="16" opacity=".35"/>
              <line x1="11" y1="48" x2="22" y2="48" opacity=".35"/>
              <line x1="11" y1="52" x2="18" y2="52" opacity=".35"/>
              <line x1="41" y1="48" x2="52" y2="48" opacity=".35"/>
              <line x1="41" y1="52" x2="48" y2="52" opacity=".35"/>
            </svg>
          </div>
          <span class="principle-num">03</span>
          <h4>Build for longevity.</h4>
          <p>Design systems that work beyond the first page, built to outlast the initial brief.</p>
        </div>
        <div class="principle" data-reveal data-reveal-delay="300">
          <div class="principle-illus" aria-hidden="true">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 56 Q 20 28 48 12" stroke-dasharray="2.5 3" opacity=".35"/>
              <rect x="6" y="52" width="14" height="5" rx="1.5"/>
              <line x1="13" y1="52" x2="13" y2="46"/>
              <path d="M38 8 L56 8 L56 26"/>
              <line x1="56" y1="8" x2="32" y2="32"/>
              <line x1="47" y1="18" x2="52" y2="13" opacity=".5"/>
              <line x1="42" y1="13" x2="47" y2="8" opacity=".5"/>
            </svg>
          </div>
          <span class="principle-num">04</span>
          <h4>Ship, then sharpen.</h4>
          <p>Get to live early, learn from real use, then improve with intent.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- =================== TEMPLATES & KITS =================== -->
  <section class="section" id="portfolio-preview">
    <div class="wrap">
      <div class="h-block" data-reveal>
        <div class="left">
          <div class="eyebrow">03 — Templates &amp; Kits</div>
          <h2>Design kits we&rsquo;ve built.</h2>
        </div>
        <p class="right">Website templates and design kits built as studio work. Proof of craft, ready to adapt.</p>
      </div>

      <div class="shop-grid">
        {
          sortedPortfolio.map((item, i) => {
            const d = item.data;
            const coverImage = d.images?.[0];
            return (
              <a
                href={`/portfolio/${item.id}`}
                class="product-card"
                data-reveal
                data-reveal-delay={i * 100}
                data-preview-url={
                  d.previewPath
                    ? `/templates/${d.previewPath}/index.html`
                    : undefined
                }
                data-preview-title={d.title}
                data-preview-cat={d.category}
              >
                {d.previewPath && (
                  <span
                    class="pv-trigger"
                    role="button"
                    tabindex="0"
                    data-preview-trigger
                    aria-label={`Preview ${d.title}`}
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
                    Preview
                  </span>
                )}
                {coverImage ? (
                  <div class="cover">
                    <img src={coverImage} alt={d.title} width={350} height={280} loading="lazy" />
                  </div>
                ) : (
                  <div class={`cover ${d.pattern} pattern-wrap`} aria-hidden="true"></div>
                )}
                <div class="body">
                  <span class="cat">{d.category}</span>
                  <div class="name-row">
                    <h3 class="name">{d.title}</h3>
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>

      <a href="/portfolio" class="section-link" data-reveal>View All Templates <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== CTA =================== -->
  <section class="section-tight">
    <div class="cta-wrap">
      <div class="cta-panel cta-panel-compact pat-heat">
        <div class="eyebrow">Let&rsquo;s talk</div>
        <h2>Got a project? <em class="italic-accent" style="color:var(--ink)">Let&rsquo;s talk.</em></h2>
        <p>Send us a brief or just tell us your idea. We reply within 1&times;24 hours (business hours).</p>
        <div class="btn-row">
          <a href="mailto:halo@roha.design" class="btn btn-cream">Email Us <span class="arr">→</span></a>
          <a href="/about#contact" class="btn btn-outline-cream">Contact Page</a>
        </div>
        <div class="arcs-deco" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!--
    TESTIMONIALS — removed until real client testimonials are available.
    Re-add this section with verified quotes before publishing to clients.
  -->

</main>
</Base>
