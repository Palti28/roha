---
import Base from '../layouts/Base.astro';
---

<Base title="Services">
<main id="main">

    <!-- HERO -->
    <section class="shop-hero">
      <div class="wrap">
        <div class="eyebrow">Products</div>
        <h1>Templates &amp; design systems<br />ready to use.</h1>
        <p class="section-lede">For founders on a sprint, designers looking for a shortcut, or anyone who doesn&rsquo;t
          want to start from scratch.</p>

        <div class="shop-filters pills" data-shop-filter>
          <button class="pill active" data-filter="all">All</button>
          <button class="pill" data-filter="ui">UI Kit</button>
          <button class="pill" data-filter="web">Website Template</button>
          <button class="pill" data-filter="figma">Figma Template</button>
          <button class="pill" data-filter="brand">Brand Template</button>
          <button class="pill" data-filter="other">Other</button>
        </div>
      </div>
    </section>

    <!-- GRID -->
    <section class="section-tight">
      <div class="wrap">
        <div class="shop-page-grid" data-shop-grid>

          <!--
            ============================================================
            PRODUCT CARD — TEMPLATE / REFERENCE
            Copy this block when adding a new product.

            REQUIRED attributes
            -------------------
            href="product-detail.html"        Card click destination (NOT the Preview button).
            class="product-card"              Required styling.
            data-category="web"               Filter pill match: all | ui | web | figma | brand | other
            data-preview-url="..."            URL loaded in the modal iframe. "#" or empty -> shows fallback.
            data-preview-title="..."          Title shown in modal header + URL pill.
            data-preview-cat="..."            Category eyebrow shown in modal header.

            OPTIONAL attributes (per-product overrides)
            -------------------------------------------
            data-preview-detail="..."         Override "View product details" button URL. "" hides it.
            data-preview-buy="..."            Override "Buy" button URL. Defaults to detail URL.
            data-preview-detail-label="..."   Custom secondary button label.
            data-preview-buy-label="..."      Custom primary button label.
            data-preview-aspect="9/16"        Iframe aspect ratio for desktop viewport.
            data-preview-viewport="mobile"    Initial viewport: desktop | tablet | mobile.
            data-preview-timeout="3000"       ms before fallback shows.

            CHILD STRUCTURE
            ---------------
            .pv-trigger    The "Preview" pill in the top-right of the cover. role="button" + tabindex.
                           Clicking this opens the modal. Clicking the card body goes to product detail.
            .cover         Pattern background: pat-arcs | pat-confetti | pat-block | pat-grid |
                           pat-stripe | pat-grain.
            .body          Holds .cat + .name-row (.name + .price).
            ============================================================
          -->
          <a href="product-detail.html" class="product-card" data-category="web"
            data-preview-url="templates/sora-landing-kit/index.html"
            data-preview-title="Sora Landing Kit"
            data-preview-cat="Website Template">
            <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Sora Landing Kit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
              Preview
            </span>
            <div class="cover pat-arcs pattern-wrap" aria-hidden="true"></div>
            <div class="body">
              <span class="cat">Website Template</span>
              <div class="name-row">
                <h3 class="name">Sora Landing Kit</h3>
                <span class="price">IDR 240k</span>
              </div>
            </div>
          </a>

          <a href="product-detail.html" class="product-card" data-category="ui"
            data-preview-url="templates/nimbus-ui-kit/index.html"
            data-preview-title="Nimbus UI Kit"
            data-preview-cat="UI Kit">
            <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Nimbus UI Kit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
              Preview
            </span>
            <div class="cover pat-confetti pattern-wrap" aria-hidden="true"></div>
            <div class="body">
              <span class="cat">UI Kit</span>
              <div class="name-row">
                <h3 class="name">Nimbus UI Kit</h3>
                <span class="price">IDR 380k</span>
              </div>
            </div>
          </a>

          <a href="product-detail.html" class="product-card" data-category="brand"
            data-preview-url="templates/terra-brand-pack/index.html"
            data-preview-title="Terra Brand Pack"
            data-preview-cat="Brand Template">
            <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Terra Brand Pack">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
              Preview
            </span>
            <div class="cover pat-block pattern-wrap" aria-hidden="true"></div>
            <div class="body">
              <span class="cat">Brand Template</span>
              <div class="name-row">
                <h3 class="name">Terra Brand Pack</h3>
                <span class="price">IDR 320k</span>
              </div>
            </div>
          </a>

          <a href="product-detail.html" class="product-card" data-category="figma"
            data-preview-url="templates/paper-portfolio-kit/index.html"
            data-preview-title="Paper Portfolio Kit"
            data-preview-cat="Figma Template">
            <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Paper Portfolio Kit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
              Preview
            </span>
            <div class="cover pat-grid pattern-wrap" aria-hidden="true"></div>
            <div class="body">
              <span class="cat">Figma Template</span>
              <div class="name-row">
                <h3 class="name">Paper Portfolio Kit</h3>
                <span class="price">IDR 180k</span>
              </div>
            </div>
          </a>

          <a href="product-detail.html" class="product-card" data-category="other"
            data-preview-url="templates/hangat-icon-set/index.html"
            data-preview-title="Hangat Icon Set"
            data-preview-cat="Icon Set">
            <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Hangat Icon Set">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
              Preview
            </span>
            <div class="cover pat-stripe pattern-wrap" aria-hidden="true"></div>
            <div class="body">
              <span class="cat">Icon Set</span>
              <div class="name-row">
                <h3 class="name">Hangat Icon Set</h3>
                <span class="price">IDR 120k</span>
              </div>
            </div>
          </a>

          <a href="product-detail.html" class="product-card" data-category="other"
            data-preview-url="templates/roha-notion-hub/index.html"
            data-preview-title="Roha Notion Hub"
            data-preview-cat="Notion Template">
            <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Roha Notion Hub">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
              Preview
            </span>
            <div class="cover pat-grain pattern-wrap" aria-hidden="true"></div>
            <div class="body">
              <span class="cat">Notion Template</span>
              <div class="name-row">
                <h3 class="name">Roha Notion Hub</h3>
                <span class="price">IDR 95k</span>
              </div>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- WHY BUY -->
    <section class="section">
      <div class="wrap">
        <div class="h-block">
          <div class="left">
            <div class="eyebrow">Why buy from Roha</div>
            <h2>Files we use ourselves, sold as they are.</h2>
          </div>
          <p class="right">Not files made just to be sold — every product here has been used on a real client project
            first.</p>
        </div>

        <div class="why-grid">
          <div class="why-card">
            <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="1.6">
                <rect x="3" y="3" width="18" height="18" rx="3" />
                <path d="M3 9h18M9 3v18" />
              </svg></span>
            <h3>Tidy design system</h3>
            <p>Tokens, components, styles — all consistent and organized.</p>
          </div>
          <div class="why-card">
            <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="1.6">
                <path d="M3 7l9-4 9 4-9 4-9-4zM3 12l9 4 9-4M3 17l9 4 9-4" />
              </svg></span>
            <h3>Organized files</h3>
            <p>Layers named, auto-layout used, pages clearly structured.</p>
          </div>
          <div class="why-card">
            <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="1.6">
                <path d="M14 3H6a2 2 0 00-2 2v14a2 2 0 002 2h12a2 2 0 002-2V9z" />
                <path d="M14 3v6h6" />
                <path d="M9 13h6M9 17h4" />
              </svg></span>
            <h3>Full documentation</h3>
            <p>Every file ships with a README — how to use it, structure, and best practices.</p>
          </div>
          <div class="why-card">
            <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="1.6">
                <path d="M21 12a9 9 0 11-3-6.7L21 8" />
                <path d="M21 3v5h-5" />
              </svg></span>
            <h3>Free updates</h3>
            <p>Buy once, get minor &amp; major updates for as long as the product is alive.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section" id="faq">
      <div class="wrap">
        <div class="h-block">
          <div class="left">
            <div class="eyebrow">Shop FAQ</div>
            <h2>Common questions.</h2>
          </div>
        </div>

        <div style="max-width:820px;">
          <div class="accordion">
            <div class="accordion-item">
              <button class="accordion-trigger">License — can I use it for client work? <span
                  class="icon">+</span></button>
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Yes. All Roha products come with a personal &amp; commercial license — usable for personal projects,
                  client work (unlimited projects), and even on products you sell. What&rsquo;s not allowed: reselling
                  the raw file itself.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger">What file formats are included? <span class="icon">+</span></button>
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Mostly Figma (.fig). Some products also have Framer, Webflow, or code (React/Astro) versions.
                  Per-product details are on each product page.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger">Can I request custom modifications? <span class="icon">+</span></button>
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Yes. After purchasing, message us on WhatsApp with your needs. We quote within 1 business day.
                  Customizations usually run IDR 5–10M depending on scope.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger">Refund policy? <span class="icon">+</span></button>
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Since these are digital products, refunds are only for cases of corrupt or wrong files. If
                  there&rsquo;s an issue, contact us within the first 24 hours.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger">Free lifetime updates? <span class="icon">+</span></button>
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Yes, as long as the product is still supported. Update notifications are sent to the email used at
                  checkout.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger">How do I buy &amp; pay? <span class="icon">+</span></button>
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  All transactions go through Mayar — we accept Bank Transfer (BCA, BNI, Mandiri), QRIS, GoPay, OVO,
                  Dana, and credit cards. Instant confirmation and download link sent to email.
                </div>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-trigger">How do I download after purchase? <span class="icon">+</span></button>
              <div class="accordion-content">
                <div class="accordion-content-inner">
                  Once payment is successful, a download link is sent automatically to your email. The link works
                  forever — you can re-download anytime.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-tight">
      <div class="cta-wrap">
        <div class="cta-panel cta-panel-compact pat-heat">
          <div class="eyebrow">Custom</div>
          <h2>Need something more <em class="italic-accent" style="color:var(--ink)">custom</em>?</h2>
          <p>If the existing templates aren&rsquo;t a fit, we also take custom requests. We quote within 1 business day.
          </p>
          <div class="btn-row">
            <a href="https://wa.me/[NO_WA]?text=Hi%20Roha%2C%20I%27d%20like%20to%20discuss%20a%20custom%20template"
              class="btn btn-cream" target="_blank" rel="noopener">Chat on WhatsApp <span class="arr">→</span></a>
            <a href="mailto:hello@rohaworks.com" class="btn btn-outline-cream">Email Us</a>
          </div>
          <div class="arcs-deco" aria-hidden="true"></div>
        </div>
      </div>
    </section>

  </main>
</Base>
