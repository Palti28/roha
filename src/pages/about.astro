---
import Base from '../layouts/Base.astro';
import { site } from '../data/site.ts';
---

<Base
  title="About"
  description="Roha is a design studio building considered, durable digital products. Clear intent, systems that last, work that ships."
>

  <main id="main">

    <!-- =================== HERO =================== -->
    <section class="about-hero">
      <div class="wrap">
        <div class="eyebrow">About</div>

        <div class="about-hero-grid">
          <h1 class="display" id="heroTitle">Roha. <em class="italic-accent">A</em> four-letter word that means a lot.</h1>
          <div class="about-hero-side">
            <p class="pull"><em>"A</em> design studio that helps people building something real ship digital products that feel considered."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- =================== THE NAME =================== -->
    <section class="section">
      <div class="wrap">
        <div class="eyebrow">01 · The Name</div>
        <h2 class="section-title">Not an acronym, not random.</h2>

        <!-- Interactive R·O·H·A display -->
        <div class="roha-display" aria-hidden="true">
          <span class="roha-char">R</span>
          <span class="roha-sep">·</span>
          <span class="roha-char">O</span>
          <span class="roha-sep">·</span>
          <span class="roha-char">H</span>
          <span class="roha-sep">·</span>
          <span class="roha-char">A</span>
        </div>

        <div class="name-grid">
          <div class="pull" data-reveal>
            <em>"Roha</em> is Batak for heart, a blend of feeling, thought, and intent. Our work tries to do the same:
            quiet on the surface, considered underneath."
          </div>
          <div data-reveal data-reveal-delay="100">
            <p>This name wasn&rsquo;t picked from a naming agency shortlist, or pulled from a generator. Roha is a word
              people from North Sumatra use every day, to describe a feeling, an intention, and a decision in a single
              word.</p>
            <p>For a studio that deals with visual decisions every day, this word feels right. It reminds us: good
              design starts with clear intent. Everything else follows.</p>
          </div>
        </div>

        <div class="name-card">
          <div class="item" data-reveal>
            <div class="k">Pronounced</div>
            <div class="v">/ˈro.ha/</div>
          </div>
          <div class="item" data-reveal data-reveal-delay="100">
            <div class="k">Origin</div>
            <div class="v">Batak Toba</div>
          </div>
          <div class="item" data-reveal data-reveal-delay="200">
            <div class="k">Translates to</div>
            <div class="v">Heart · Mind · Soul</div>
          </div>
        </div>
      </div>
    </section>

    <!-- =================== PRINCIPLES =================== -->
    <section class="section">
      <div class="wrap">
        <div class="section-head">
          <div class="eyebrow">02 · Principles</div>
          <h2 class="section-title">Four things we hold to.</h2>
        </div>

        <div class="principles-grid">
          <div class="principle tilt-card" data-reveal>
            <div class="tilt-shine"></div>
            <div class="num">01</div>
            <h3>Quiet on the surface, considered underneath.</h3>
            <p>Design that doesn&rsquo;t shout, but every choice has a reason. Spacing, sizing, color, we can explain
              all of it if you ask.</p>
          </div>
          <div class="principle tilt-card" data-reveal data-reveal-delay="100">
            <div class="tilt-shine"></div>
            <div class="num">02</div>
            <h3>Craft is a discipline.</h3>
            <p>The details that make work feel right aren&rsquo;t accidents. They&rsquo;re chosen, measured, and
              intentional, decided on purpose rather than left to default.</p>
          </div>
          <div class="principle tilt-card" data-reveal data-reveal-delay="200">
            <div class="tilt-shine"></div>
            <div class="num">03</div>
            <h3>Systems, not decoration.</h3>
            <p>We build design systems, not one pretty page that falls apart on the second update. Components, tokens,
              documentation, so it still feels right a year from now.</p>
          </div>
          <div class="principle tilt-card" data-reveal data-reveal-delay="300">
            <div class="tilt-shine"></div>
            <div class="num">04</div>
            <h3>Ship it, don&rsquo;t polish it forever.</h3>
            <p>Shipped &gt; perfect. Better a 1.0 that&rsquo;s live than a 0.9 that&rsquo;s delayed. What matters is
              knowing what to improve in the next iteration.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- =================== CRAFT LAB =================== -->
    <section class="section lab-section">
      <div class="wrap">
        <div class="section-head">
          <div class="eyebrow">03 · Craft Lab</div>
          <h2 class="section-title">Interactions, built from scratch.</h2>
          <p class="section-lede">No animation libraries. Every interaction you see here is hand-coded, tuned for the exact feeling it creates.</p>
        </div>

        <div class="lab-grid">

          <!-- Demo 1: Magnetic Pull -->
          <div class="lab-demo" id="demoMagnetic">
            <div class="lab-label">Magnetic Pull</div>
            <div class="lab-body lab-body--center">
              <p class="lab-hint">Move your cursor near the button</p>
              <button class="btn btn-primary mag-btn" id="magBtn">Work with us →</button>
            </div>
            <div class="lab-tech">mousemove + transform</div>
          </div>

          <!-- Demo 2: Text Scramble -->
          <div class="lab-demo">
            <div class="lab-label">Text Scramble</div>
            <div class="lab-body lab-body--center">
              <p class="lab-hint">Hover the text</p>
              <p class="scramble-el" data-original="Design is intent.">Design is intent.</p>
            </div>
            <div class="lab-tech">RAF + char cycling</div>
          </div>

          <!-- Demo 3: Stagger Reveal -->
          <div class="lab-demo">
            <div class="lab-label">Stagger Reveal</div>
            <div class="lab-body lab-body--stagger">
              <div class="stagger-container" id="staggerContainer">
                <div class="stag-line">Considered</div>
                <div class="stag-line">at every</div>
                <div class="stag-line">scale.</div>
              </div>
              <button class="stagger-replay" id="staggerReplay">&#8635; Replay</button>
            </div>
            <div class="lab-tech">CSS keyframes + JS stagger</div>
          </div>

        </div>
      </div>
    </section>

    <!-- =================== TOOLS =================== -->
    <section class="section">
      <div class="wrap">
        <div class="eyebrow">05 · Disciplines &amp; Tools</div>

        <div class="tools-grid">
          <div data-reveal>
            <h3>What we do.</h3>
            <ul>
              <li><a href="/services#product-design">Product Design (UI/UX)</a></li>
              <li><a href="/services#web">Website Development</a></li>
              <li><a href="/services#landing">Landing Page</a></li>
              <li><a href="/services#brand">Brand &amp; Logo</a></li>
            </ul>
          </div>
          <div data-reveal data-reveal-delay="150">
            <h3>Tools we use.</h3>
            <ul>
              <li>Figma <span class="tag">Design</span></li>
              <li>Framer · Webflow <span class="tag">No-code</span></li>
              <li>Next.js · Astro <span class="tag">Code</span></li>
              <li>Notion <span class="tag">Docs</span></li>
              <li>Linear · Loom <span class="tag">Workflow</span></li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- =================== CONTACT =================== -->
    <section class="section" id="contact">
      <div class="wrap">
        <div class="section-head">
          <div class="eyebrow">06 · Contact Us</div>
          <h2 class="section-title">Let&rsquo;s talk.</h2>
          <p class="section-lede">Send a brief, a Notion link, or just a story. We reply within 1&times;24 hours (business
            hours).</p>
        </div>

        <div class="contact-grid">

          <form class="contact-form" data-contact-form data-reveal data-mailto="hello@rohaworks.com" novalidate>

            <div class="field-row">
              <div class="field">
                <label for="name">Name</label>
                <input id="name" name="name" type="text" required placeholder="Your name" />
                <span class="field-error">Please enter your name.</span>
              </div>
              <div class="field">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" required placeholder="you@email.com" />
                <span class="field-error">Email is not valid.</span>
              </div>
            </div>

            <div class="field-row">
              <div class="field">
                <label for="type">Project Type</label>
                <select id="type" name="type" required>
                  <option value="">Pick one</option>
                  <option>Product Design (UI/UX)</option>
                  <option>Website Development</option>
                  <option>Landing Page</option>
                  <option>Brand &amp; Logo</option>
                  <option>Other</option>
                </select>
                <span class="field-error">Please pick a project type.</span>
              </div>
              <div class="field">
                <label for="budget">Budget</label>
                <select id="budget" name="budget" required>
                  <option value="">Pick one</option>
                  <option>Small</option>
                  <option>Medium</option>
                  <option>Large</option>
                  <option>Not sure yet</option>
                </select>
                <span class="field-error">Please pick a budget range.</span>
              </div>
            </div>

            <div class="field">
              <label for="msg">Message</label>
              <textarea id="msg" name="message" required
                placeholder="A short note about your project: timeline, goals, or reference links if you have any."></textarea>
              <span class="field-error">Tell us a bit about your project.</span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg">Send Message <span class="arr">→</span></button>
          </form>

          <div class="contact-info" data-reveal data-reveal-delay="150">
            <div class="contact-info-block">
              <div class="k">Email</div>
              <div class="v"><a href="mailto:hello@rohaworks.com">hello@rohaworks.com</a></div>
            </div>
            <div class="contact-info-block">
              <div class="k">WhatsApp</div>
              <div class="v"><a href={`https://wa.me/${site.wa}?text=Halo%20Roha%2C%20saya%20ingin%20diskusi%20project%20bareng.`} target="_blank" rel="noopener">Chat on WhatsApp →</a></div>
            </div>
            <div class="contact-info-block">
              <div class="k">Location</div>
              <div class="v">Indonesia</div>
            </div>
            <div class="contact-info-block">
              <div class="k">Working Hours</div>
              <div class="v">Mon–Fri, 09:00–17:00 WIB</div>
              <p>We reply within 1&times;24 hours (business hours).</p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <script>
    // ============================================================
    // About page — interactive layer
    // ============================================================

    const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    // ---- 3D tilt on principle cards ----
    if (canHover) {
      document.querySelectorAll('.tilt-card').forEach(card => {
        card.addEventListener('mousemove', e => {
          const r  = card.getBoundingClientRect();
          const cx = r.left + r.width  / 2;
          const cy = r.top  + r.height / 2;
          const dx = (e.clientX - cx) / (r.width  / 2);
          const dy = (e.clientY - cy) / (r.height / 2);
          card.style.transform = `perspective(700px) rotateX(${(-dy * 8).toFixed(2)}deg) rotateY(${(dx * 8).toFixed(2)}deg) translateZ(6px)`;
          const shine = card.querySelector('.tilt-shine');
          if (shine) {
            const px = (((dx + 1) / 2) * 100).toFixed(1);
            const py = (((dy + 1) / 2) * 100).toFixed(1);
            shine.style.background = `radial-gradient(circle at ${px}% ${py}%, rgba(255,255,255,.2) 0%, transparent 65%)`;
          }
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = '';
          const shine = card.querySelector('.tilt-shine');
          if (shine) shine.style.background = '';
        });
      });
    }

    // ---- Magnetic button ----
    if (canHover) {
      const zone   = document.getElementById('demoMagnetic');
      const magBtn = document.getElementById('magBtn');
      if (zone && magBtn) {
        zone.addEventListener('mousemove', e => {
          const r  = magBtn.getBoundingClientRect();
          const cx = r.left + r.width  / 2;
          const cy = r.top  + r.height / 2;
          magBtn.style.transform = `translate(${((e.clientX - cx) * 0.42).toFixed(1)}px, ${((e.clientY - cy) * 0.42).toFixed(1)}px)`;
        });
        zone.addEventListener('mouseleave', () => {
          magBtn.style.transform = '';
        });
      }
    }

    // ---- Text scramble ----
    const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz!@#$%&?';

    function scramble(el) {
      const original = el.dataset.original || el.textContent;
      let frame = 0;
      const total = 30;
      function tick() {
        el.textContent = original.split('').map((ch, i) => {
          if (ch === ' ') return ' ';
          if (frame / total > i / original.length) return ch;
          return CHARS[Math.floor(Math.random() * CHARS.length)];
        }).join('');
        frame++;
        if (frame <= total) requestAnimationFrame(tick);
        else el.textContent = original;
      }
      tick();
    }

    document.querySelectorAll('.scramble-el').forEach(el => {
      let active = false;
      el.addEventListener('mouseenter', () => {
        if (active) return;
        active = true;
        scramble(el);
        setTimeout(() => { active = false; }, 700);
      });
    });

    // ---- Stagger reveal ----
    const staggerContainer = document.getElementById('staggerContainer');
    const replayBtn        = document.getElementById('staggerReplay');

    function runStagger() {
      const lines = staggerContainer?.querySelectorAll('.stag-line');
      if (!lines) return;
      lines.forEach(l => {
        l.classList.remove('stag-in');
        void (l as HTMLElement).offsetWidth; // force reflow
      });
      lines.forEach((l, i) => {
        setTimeout(() => l.classList.add('stag-in'), i * 130 + 60);
      });
    }

    runStagger();
    replayBtn?.addEventListener('click', runStagger);
  </script>

</Base>
