---
// src/pages/portfolio/[slug].astro
// Portfolio item detail page.
// Structure & class names mirror the original so portfolio.css + preview.js apply as-is.

import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { productSchema } from '../../utils/schema';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const all = (await getCollection('portfolio', ({ data }) => !data.draft))
    .sort((a, b) => a.data.order - b.data.order);

  return all.map((entry) => ({
    params: { slug: entry.id },
    props: {
      entry,
      // "Related" = up to 3 other portfolio items, in order, wrapping around.
      related: all.filter((p) => p.id !== entry.id).slice(0, 3),
    },
  }));
}

const { entry, related } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

// Generate product schema
const productSchemaData = productSchema({
  title: d.title,
  summary: d.summary,
  category: d.category,
  image: d.images?.[0],
  url: `/portfolio/${entry.id}/`,
  siteUrl: site.url,
});
---

<Base
  title={`${d.title} — ${d.category}`}
  description={d.summary}
  image={d.images?.[0]}
  type="product"
  schema={productSchemaData}
>
  <main id="main">

    {/* STICKY PRODUCT BAR */}
    <div class="pd-stickybar" id="pdStickyBar" aria-hidden="true">
      <div class="wrap pd-stickybar-inner">
        <div class="pd-stickybar-title">
          <span class="cat">{d.category}</span>
          <h2>{d.title}</h2>
        </div>
        <div class="pd-stickybar-actions">
          {d.previewPath && (
            <button type="button" class="btn btn-primary btn-sm"
              data-preview-trigger
              data-preview-url={`templates/${d.previewPath}/index.html`}
              data-preview-title={d.title}
              data-preview-cat={d.category}>
              Preview
            </button>
          )}
        </div>
      </div>
    </div>

    {/* PRODUCT HERO */}
    <section class="pd-hero" id="pdHero" style="padding: 32px 0px">
      <div class="wrap">
        <div class="pd-hero-grid">
          {d.images && d.images.length > 0 ? (
            <div class="pd-cover">
              <img src={d.images[0]} alt={d.title} width={500} height={400} />
            </div>
          ) : (
            <div class={`pd-cover ${d.pattern} pattern-wrap`} aria-hidden="true"></div>
          )}
          <div class="pd-info">
            <span class="cat">{d.category}</span>
            <h1>{d.title}</h1>
            <p class="tagline">{d.tagline}</p>

            <div class="pd-actions">
              {d.previewPath && (
                <button type="button" class="btn btn-primary"
                  data-preview-trigger
                  data-preview-url={`templates/${d.previewPath}/index.html`}
                  data-preview-title={d.title}
                  data-preview-cat={d.category}>
                  Preview
                </button>
              )}
            </div>

            {d.format === 'figma' && d.figmaUrl && (
              <div class="pd-actions-tertiary">
                <a href={d.figmaUrl} class="btn btn-tertiary" target="_blank" rel="noopener">
                  Figma Preview <span class="arr">→</span>
                </a>
              </div>
            )}

            <div class="pd-trust">
              <div><span class="ok">✓</span> Personal &amp; commercial license</div>
              <div><span class="ok">✓</span> Well-documented &amp; organized</div>
              <div><span class="ok">✓</span> Ready to adapt &amp; customize</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* PREVIEW GALLERY — single column, full width */}
    {d.images && d.images.length > 0 && (
      <section class="section" id="preview-gallery">
        <div class="wrap">
          <div class="preview-grid">
            {d.images.map((img, i) => (
              <div class="preview-item" data-reveal data-reveal-delay={i * 100}>
                <img src={img} alt="Product preview" loading="lazy" width={600} height={400} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* OVERVIEW & SPECS — Side by side layout */}
    <section class="section" id="product-details">
      <div class="wrap">
        <div class="product-details-grid">
          <div class="product-overview" data-reveal>
            <div class="prose">
              <Content />
            </div>
          </div>

          <aside class="product-specs" data-reveal data-reveal-delay="150">
            <div class="specs-card">
              <div class="specs-header">
                <h3>What's Included</h3>
              </div>
              <div class="specs-body">
                <div class="spec-item">
                  <span class="spec-label">Format</span>
                  <span class="spec-value">{d.format === 'figma' ? 'Figma' : 'HTML/CSS/JS'}</span>
                </div>
                <div class="spec-item">
                  <span class="spec-label">Status</span>
                  <span class="spec-value">{d.status === 'available' ? '✓ Available' : d.status === 'soon' ? 'Coming Soon' : 'Sold Out'}</span>
                </div>
                {d.previewPath && (
                  <div class="spec-item">
                    <span class="spec-label">Preview</span>
                    <span class="spec-value">Live Preview</span>
                  </div>
                )}
                <div class="spec-item">
                  <span class="spec-label">License</span>
                  <span class="spec-value">Personal & Commercial</span>
                </div>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    {/* RELATED — auto, up to 3 other products */}
    {related.length > 0 && (
      <section class="section">
        <div class="wrap">
          <div class="h-block">
            <div class="left">
              <div class="eyebrow">Other Products</div>
              <h2>You might like these too.</h2>
            </div>
            <p class="right">
              <a href="/portfolio/" class="section-link" style="margin-top:0;">
                See all products <span class="arr">→</span>
              </a>
            </p>
          </div>

          <div class="pd-related">
            {related.map((p) => {
              const coverImage = p.data.images?.[0];
              return (
                <a href={`/portfolio/${p.id}/`} class="product-card">
                  {coverImage ? (
                    <div class="cover">
                      <img src={coverImage} alt={p.data.title} width={350} height={280} loading="lazy" />
                    </div>
                  ) : (
                    <div class={`cover ${p.data.pattern} pattern-wrap`} aria-hidden="true"></div>
                  )}
                  <div class="body">
                    <span class="cat">{p.data.category}</span>
                    <div class="name-row">
                      <h3 class="name">{p.data.title}</h3>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

  </main>
</Base>

<script>
  // Sticky product bar — show after hero scrolls out of view
  const hero = document.getElementById('pdHero');
  const bar = document.getElementById('pdStickyBar');
  if (hero && bar) {
    const io = new IntersectionObserver(
      ([entry]) => bar.classList.toggle('is-stuck', !entry.isIntersecting),
      { rootMargin: '-80px 0px 0px 0px', threshold: 0 }
    );
    io.observe(hero);
  }
</script>
