---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import CaseTag from "../components/CaseTag.astro";

// 1. Ambil data collection 'work' & filter out draft
const allWork = await getCollection("work", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// 2. Urutkan berdasarkan property 'order'
const sortedWork = allWork.sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Work"
  description="Case studies and projects from Roha, UI/UX, brand identity, and web design for founders and small teams."
>
  <Nav />
  <main id="main">
    <section class="work-hero">
      <div class="wrap">
        <div class="work-hero-grid">
          <div class="work-hero-left">
            <div class="eyebrow">Work</div>
            <h1 data-reveal>What we&rsquo;ve shipped.</h1>
            <p class="section-lede" data-reveal data-reveal-delay="100">
              A small list, but every project has a story. Pick one to read in
              detail.
            </p>

            <div class="work-filter pills" data-work-filter>
              <button class="pill active" data-filter="all">All</button>
              <button class="pill" data-filter="uiux">UI/UX</button>
              <button class="pill" data-filter="web">Web Dev</button>
              <button class="pill" data-filter="branding">Branding</button>
            </div>
          </div>

          <div class="work-hero-figure" data-reveal data-reveal-delay="200">
            <svg viewBox="0 0 460 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="work-illus" role="img" aria-label="Illustration of a shipped website in a browser with a mobile preview and a delivered projects card">

              <!-- accents -->
              <path d="M430 320 a44 44 0 0 0 -44 -44" stroke="var(--terracotta-soft)" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
              <circle cx="420" cy="46" r="2.5" fill="var(--terracotta-soft)" opacity="0.5"/>
              <circle cx="36" cy="338" r="3" fill="var(--terracotta-soft)" opacity="0.5"/>

              <!-- BROWSER WINDOW -->
              <rect x="28" y="48" width="276" height="210" rx="10" fill="var(--paper)" stroke="var(--rule)" stroke-width="1.5"/>
              <line x1="28" y1="78" x2="304" y2="78" stroke="var(--rule)" stroke-width="1.5"/>
              <circle cx="48" cy="63" r="4" fill="var(--terracotta)"/>
              <circle cx="60" cy="63" r="4" fill="var(--rule)"/>
              <circle cx="72" cy="63" r="4" fill="var(--rule)"/>
              <rect x="88" y="55" width="136" height="16" rx="8" fill="var(--paper-tint)" stroke="var(--rule)" stroke-width="1"/>
              <rect x="234" y="55" width="56" height="16" rx="8" fill="var(--terracotta)"/>
              <circle cx="244" cy="63" r="2.5" fill="white" opacity="0.9"/>
              <text x="250" y="67" font-family="'Geist Mono', monospace" font-size="6.5" fill="white" letter-spacing=".1em" opacity="0.95">LIVE</text>

              <!-- nav -->
              <rect x="40" y="85" width="44" height="8" rx="4" fill="var(--ink)" opacity="0.14"/>
              <rect x="218" y="86" width="26" height="6" rx="3" fill="var(--ink)" opacity="0.09"/>
              <rect x="250" y="86" width="22" height="6" rx="3" fill="var(--ink)" opacity="0.09"/>
              <rect x="278" y="86" width="18" height="6" rx="3" fill="var(--ink)" opacity="0.09"/>
              <line x1="28" y1="100" x2="304" y2="100" stroke="var(--rule)" stroke-width="1"/>

              <!-- hero section -->
              <rect x="28" y="100" width="276" height="78" fill="var(--paper-tint)"/>
              <rect x="40" y="112" width="152" height="13" rx="6.5" fill="var(--ink)" opacity="0.18"/>
              <rect x="40" y="131" width="120" height="13" rx="6.5" fill="var(--ink)" opacity="0.14"/>
              <rect x="40" y="151" width="164" height="7" rx="3.5" fill="var(--ink)" opacity="0.09"/>
              <rect x="40" y="162" width="64" height="18" rx="5" fill="var(--terracotta)"/>
              <line x1="50" y1="171" x2="90" y2="171" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="28" y1="178" x2="304" y2="178" stroke="var(--rule)" stroke-width="1"/>

              <!-- content 2-col -->
              <rect x="40" y="188" width="110" height="60" rx="4" fill="var(--paper-tint)" stroke="var(--rule)" stroke-width="1"/>
              <circle cx="78" cy="215" r="10" stroke="var(--terracotta)" stroke-width="1.5" opacity="0.6"/>
              <path d="M44 244 L60 228 L74 238 L88 222 L150 244" stroke="var(--ink)" stroke-width="1" stroke-linejoin="round" opacity="0.22"/>
              <rect x="162" y="188" width="110" height="60" rx="4" fill="var(--paper-tint)" stroke="var(--rule)" stroke-width="1"/>
              <rect x="170" y="200" width="84" height="7" rx="3.5" fill="var(--ink)" opacity="0.12"/>
              <rect x="170" y="213" width="70" height="7" rx="3.5" fill="var(--ink)" opacity="0.12"/>
              <rect x="170" y="226" width="78" height="7" rx="3.5" fill="var(--ink)" opacity="0.12"/>

              <!-- MOBILE DEVICE -->
              <rect x="314" y="78" width="88" height="150" rx="14" fill="var(--paper)" stroke="var(--rule)" stroke-width="1.5"/>
              <rect x="344" y="80" width="28" height="8" rx="4" fill="var(--paper-tint)" stroke="var(--rule)" stroke-width="1"/>
              <rect x="324" y="95" width="36" height="6" rx="3" fill="var(--ink)" opacity="0.13"/>
              <line x1="314" y1="107" x2="402" y2="107" stroke="var(--rule)" stroke-width="1"/>
              <rect x="314" y="107" width="88" height="50" fill="var(--paper-tint)"/>
              <rect x="322" y="116" width="60" height="8" rx="4" fill="var(--ink)" opacity="0.15"/>
              <rect x="322" y="130" width="48" height="8" rx="4" fill="var(--ink)" opacity="0.11"/>
              <rect x="322" y="144" width="36" height="14" rx="3" fill="var(--terracotta)" opacity="0.85"/>
              <line x1="314" y1="157" x2="402" y2="157" stroke="var(--rule)" stroke-width="1"/>
              <rect x="322" y="164" width="60" height="5" rx="2.5" fill="var(--ink)" opacity="0.1"/>
              <rect x="322" y="175" width="48" height="5" rx="2.5" fill="var(--ink)" opacity="0.1"/>
              <rect x="322" y="186" width="54" height="5" rx="2.5" fill="var(--ink)" opacity="0.1"/>
              <rect x="347" y="218" width="16" height="4" rx="2" fill="var(--rule)" opacity="0.5"/>

              <!-- FLOATING DELIVERED CARD -->
              <rect x="262" y="246" width="164" height="90" rx="10" fill="var(--paper)" stroke="var(--rule)" stroke-width="1.5"/>
              <text x="276" y="264" font-family="'Geist Mono', monospace" font-size="7" fill="var(--ink)" letter-spacing=".14em" opacity="0.38">DELIVERED</text>
              <line x1="262" y1="272" x2="426" y2="272" stroke="var(--rule)" stroke-width="1"/>
              <rect x="262" y="271" width="38" height="2" rx="1" fill="var(--terracotta)" opacity="0.5"/>
              <text x="276" y="300" font-family="'Bricolage Grotesque', serif" font-size="22" fill="var(--ink)" font-weight="300" opacity="0.7">4</text>
              <text x="276" y="316" font-family="'Geist Mono', monospace" font-size="6" fill="var(--ink)" letter-spacing=".1em" opacity="0.4">PROJECTS</text>
              <text x="344" y="300" font-family="'Bricolage Grotesque', serif" font-size="22" fill="var(--ink)" font-weight="300" opacity="0.7">~4W</text>
              <text x="344" y="316" font-family="'Geist Mono', monospace" font-size="6" fill="var(--ink)" letter-spacing=".1em" opacity="0.4">AVG TIME</text>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <section class="section-tight">
      <div class="wrap">
        <div class="work-grid">
          {
            sortedWork.map((project, idx) => {
              const {
                title,
                summary,
                category,
                service,
                duration,
                year,
                client,
                pattern,
                coverImage,
                concept,
                tagLabel,
              } = project.data;
              return (
                <a
                  href={`/work/${project.id}`}
                  class="work-card"
                  data-category={category}
                  data-reveal
                  data-reveal-delay={idx * 120}
                >
                  {coverImage ? (
                    <img src={coverImage} alt={`${title} — case study cover`} class="thumb" width={400} height={300} loading="lazy" />
                  ) : (
                    <div
                      class={`thumb ${pattern} pattern-wrap`}
                      aria-hidden="true"
                    />
                  )}

                  <div class="meta-row">
                    <span class="tag">{service}</span>
                    <span class="meta-tag">{year}</span>
                    <CaseTag concept={concept} label={tagLabel} tone="light" />
                  </div>

                  <h3>{title}</h3>
                  <p class="summary">{summary}</p>

                  <div class="meta-bottom">
                    <span>{client}</span>
                    <span>·</span>
                    <span>{duration}</span>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>

    <section class="section-tight">
      <div class="cta-wrap">
        <div class="cta-panel cta-panel-compact pat-heat">
          <div class="eyebrow">Next Project</div>
          <h2>
            Want to be our <em class="italic-accent" style="color:var(--ink)"
              >next</em
            > project?
          </h2>
          <p>
            Roha takes on a limited number of projects at once, so each one gets
            full attention. Send your brief first.
          </p>
          <div class="btn-row">
            <a href="/about#contact" class="btn btn-cream"
              >Start a Project <span class="arr">→</span></a
            >
            <a href="mailto:hello@rohaworks.com" class="btn btn-outline-cream"
              >Email Us</a
            >
          </div>
          <div class="arcs-deco" aria-hidden="true"></div>
        </div>
      </div>
    </section>
  </main>
</Base>
