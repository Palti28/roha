                <rect x="14" y="89" width="182" height="14" rx="3" fill="white" fill-opacity=".03"/><rect x="14" y="90" width="4" height="12" rx="1.5" fill="white" fill-opacity=".15"/><rect x="24" y="94" width="104" height="5" rx="2" fill="white" fill-opacity=".18"/>
