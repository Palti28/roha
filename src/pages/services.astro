                <rect x="14" y="92" width="18" height="5" rx="2" fill="white" fill-opacity=".12"/>
                <rect x="14" y="106" width="18" height="5" rx="2" fill="white" fill-opacity=".12"/>
                <rect x="14" y="120" width="18" height="5" rx="2" fill="white" fill-opacity=".12"/>
                <rect x="14" y="134" width="18" height="5" rx="2" fill="white" fill-opacity=".12"/>
                <rect x="14" y="148" width="18" height="5" rx="2" fill="white" fill-opacity=".12"/>
                <line x1="40" y1="0" x2="40" y2="220" stroke="white" stroke-opacity=".06" stroke-width="1"/>
                <!-- code lines — tag keywords in terracotta, content muted white -->
                <rect x="48" y="20" width="28" height="7" rx="2" fill="#c1440e" fill-opacity=".5"/>
                <rect x="82" y="20" width="56" height="7" rx="2" fill="white" fill-opacity=".22"/>
                <rect x="144" y="20" width="36" height="7" rx="2" fill="#c1440e" fill-opacity=".3"/>
