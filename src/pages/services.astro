                <rect x="256" y="22" width="360" height="176" rx="8" fill="white" fill-opacity=".05" stroke="#c1440e" stroke-opacity=".45" stroke-width="1" stroke-dasharray="4 2"/>
                <rect x="268" y="32" width="336" height="88" rx="4" fill="#c1440e" fill-opacity=".18"/>
                <rect x="352" y="62" width="168" height="8" rx="4" fill="#c1440e" fill-opacity=".32"/>
                <rect x="268" y="132" width="172" height="9" rx="4" fill="white" fill-opacity=".28"/>
