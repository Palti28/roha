---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';

const portfolio = (await getCollection('portfolio', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Roha"
  description="Roha is a design studio building websites, UI/UX, and brand systems that are considered, durable, and ready to ship."
>
  <main id="main">

    <!-- =================== HERO =================== -->
    <section class="lp-hero">
      <div class="lp-hero-inner">
        <div class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>Digital Design Studio &middot; Indonesia</div>
        <h1 class="lp-hero-title">A quiet<br />kind of<br /><em class="italic-accent">warm.</em></h1>
        <p class="lp-hero-tagline">A digital design studio made warm, shipped tidy. We design and build websites, landing pages, and brand identities for founders who care about craft.</p>
        <dl class="lp-stats">
          <div class="lp-stat">
            <dt>2021</dt>
            <dd>Founded</dd>
          </div>
          <div class="lp-stat">
            <dt>1&ndash;2 wk</dt>
            <dd>Turnaround</dd>
          </div>
          <div class="lp-stat">
            <dt>Indonesia</dt>
            <dd>Based in</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- =================== MAIN NAV (sticky trigger) =================== -->
    <Nav />

    <!-- =================== WORK GRID =================== -->
    <section class="lp-work">
      <div class="lp-work-inner">
        <div class="lp-work-head">
          <div class="eyebrow"><span class="eyebrow-line" aria-hidden="true"></span>Selected Work</div>
          <h2 class="lp-work-title">Projects &amp; Case Studies</h2>
        </div>

        <div class="lp-grid">
          {
            portfolio.map((item) => {
              const d = item.data;
              const cover = d.images?.[0];
              const initial = d.title.trim().charAt(0).toUpperCase();
              return (
                <a href={`/portfolio/${item.id}`} class="lp-tile">
                  <div class="lp-thumb">
                    {cover ? (
                      <img src={cover} alt={d.title} width="400" height="400" loading="lazy" />
                    ) : (
                      <div class="lp-thumb-fallback" aria-hidden="true"><span>{initial}</span></div>
                    )}
                  </div>
                  <div class="lp-tile-body">
                    <span class="lp-tag">{d.category}</span>
                    <h3 class="lp-tile-title">{d.title}</h3>
                    <p class="lp-tile-desc">{d.tagline}</p>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>

  </main>
</Base>
