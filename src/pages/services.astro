                <rect x="268" y="162" width="96" height="22" rx="11" fill="#c1440e" fill-opacity=".58"/>
                <!-- corner handles -->
                <rect x="252" y="18" width="7" height="7" rx="1.5" fill="#c1440e" fill-opacity=".8"/>
                <rect x="613" y="18" width="7" height="7" rx="1.5" fill="#c1440e" fill-opacity=".8"/>
                <rect x="252" y="193" width="7" height="7" rx="1.5" fill="#c1440e" fill-opacity=".8"/>
                <rect x="613" y="193" width="7" height="7" rx="1.5" fill="#c1440e" fill-opacity=".8"/>
                <rect x="430" y="18" width="7" height="7" rx="1.5" fill="white" fill-opacity=".28"/>
                <rect x="430" y="193" width="7" height="7" rx="1.5" fill="white" fill-opacity=".28"/>
                <!-- inspect panel -->
                <text x="674" y="20" font-family="monospace" font-size="7" letter-spacing=".14em" fill="white" fill-opacity=".25">INSPECT</text>
                <text x="674" y="42" font-family="monospace" font-size="7" letter-spacing=".08em" fill="white" fill-opacity=".2">FILL</text>
                <circle cx="712" cy="54" r="10" fill="#c1440e" fill-opacity=".7"/>
                <rect x="730" y="49" width="56" height="7" rx="3" fill="white" fill-opacity=".2"/>
                <rect x="730" y="60" width="40" height="5" rx="2" fill="white" fill-opacity=".12"/>
                <text x="674" y="84" font-family="monospace" font-size="7" letter-spacing=".08em" fill="white" fill-opacity=".2">TYPOGRAPHY</text>
                <rect x="674" y="91" width="100" height="7" rx="3" fill="white" fill-opacity=".15"/>
                <rect x="674" y="104" width="72" height="6" rx="3" fill="white" fill-opacity=".1"/>
                <text x="674" y="124" font-family="monospace" font-size="7" letter-spacing=".08em" fill="white" fill-opacity=".2">SPACING</text>
                <rect x="674" y="131" width="56" height="6" rx="3" fill="white" fill-opacity=".15"/>
                <rect x="674" y="143" width="40" height="6" rx="3" fill="white" fill-opacity=".1"/>
                <rect x="674" y="162" width="72" height="16" rx="8" fill="white" fill-opacity=".05" stroke="white" stroke-opacity=".12" stroke-width="1"/>
                <rect x="752" y="162" width="60" height="16" rx="8" fill="white" fill-opacity=".05" stroke="white" stroke-opacity=".12" stroke-width="1"/>
                <rect x="674" y="184" width="84" height="16" rx="8" fill="#c1440e" fill-opacity=".18" stroke="#c1440e" stroke-opacity=".3" stroke-width="1"/>
              </svg>
            </div>
            <div class="num">01</div>
            <div class="core">
              <h3>Product Design (UI/UX)</h3>
              <p>One full flow from research to developer handoff. For products chasing product-market fit, ones that
