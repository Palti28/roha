                <rect x="14" y="41" width="182" height="14" rx="3" fill="white" fill-opacity=".03"/><rect x="14" y="42" width="4" height="12" rx="1.5" fill="white" fill-opacity=".15"/><rect x="24" y="46" width="120" height="5" rx="2" fill="white" fill-opacity=".18"/>
                <rect x="14" y="57" width="182" height="14" rx="3" fill="#c1440e" fill-opacity=".12"/><rect x="14" y="58" width="4" height="12" rx="1.5" fill="#c1440e" fill-opacity=".7"/><rect x="24" y="62" width="68" height="5" rx="2" fill="white" fill-opacity=".42"/>
