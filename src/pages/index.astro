---
import Base from '../layouts/Base.astro';
---

<Base title="Home">
  <main id="main">

  <!-- =================== HERO =================== -->
  <section class="home-hero">
    <div class="wrap">
      <div class="eyebrow">Design Studio · Est. 2026</div>

      <div class="home-hero-grid">
        <h1 class="display">Digital design<br/>made <em class="italic-accent">warm</em>,<br/>shipped tidy.</h1>

        <div class="home-hero-meta">
          <p>Roha is a small studio that helps founders and indie makers build websites, UI/UX, and brands that feel real — not just thrown together.</p>
          <div class="btn-row">
            <a href="work.html" class="btn btn-primary">See Our Work <span class="arr">→</span></a>
            <a href="about.html#contact" class="btn btn-secondary">Contact Us</a>
          </div>
        </div>
      </div>

      <div class="hero-stripe" aria-hidden="true">
        <span style="background:var(--terracotta)"></span>
        <span style="background:var(--terracotta-soft)"></span>
        <span style="background:var(--mustard)"></span>
        <span style="background:var(--sand)"></span>
        <span style="background:var(--cream)"></span>
        <span style="background:var(--clay)"></span>
        <span style="background:var(--ink)"></span>
      </div>
    </div>
  </section>

  <!-- =================== FEATURED WORK =================== -->
  <section class="section" id="work-preview">
    <div class="wrap">
      <div class="h-block">
        <div class="left">
          <div class="eyebrow">01 — Featured Work</div>
          <h2>What we&rsquo;ve shipped.</h2>
        </div>
        <p class="right">Two projects — a small list, but each has a story. Pick one to read in detail.</p>
      </div>

      <div class="featured-grid">

        <a href="/templates/car-rental/index.html" class="project-card">
          <div class="thumb pat-arcs pattern-wrap" aria-hidden="true"></div>
          <div class="meta-row">
            <span class="tag">Web Design &amp; Dev</span>
            <span class="year">2025</span>
          </div>
          <h3>Sora Landing Kit</h3>
          <p class="summary">A landing kit for founders in a hurry — from zero to a system that can be reused over and over.</p>
        </a>

        <a href="work-detail.html" class="project-card">
          <div class="thumb pat-grid pattern-wrap" aria-hidden="true"></div>
          <div class="meta-row">
            <span class="tag">UX &amp; UI Design</span>
            <span class="year">2026</span>
          </div>
          <h3>Nimbus Dashboard</h3>
          <p class="summary">An internal tool that&rsquo;s finally enjoyable to use — a data-heavy dashboard redesign for an ops team.</p>
        </a>

      </div>

      <a href="work.html" class="section-link">All Work <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== SHOP PREVIEW =================== -->
  <section class="section" id="shop-preview">
    <div class="wrap">
      <div class="h-block">
        <div class="left">
          <div class="eyebrow">02 — Digital Products</div>
          <h2>Templates for those on a sprint.</h2>
        </div>
        <p class="right">Files we&rsquo;ve used on our own client projects — now you can use them too. Tidy, documented, easy to fork.</p>
      </div>

      <div class="shop-grid">

          <a href="product-detail.html" class="product-card"
            data-preview-url="/templates/car-rental/index.html"
           data-preview-title="Sora Landing Kit"
           data-preview-cat="Website Template">
          <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Sora Landing Kit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </span>
          <div class="cover pat-arcs pattern-wrap" aria-hidden="true"></div>
          <div class="body">
            <span class="cat">Website Template</span>
            <div class="name-row">
              <h3 class="name">Sorana Landing Kit</h3>
              <span class="price">IDR 240k</span>
            </div>
          </div>
        </a>

          <a href="product-detail.html" class="product-card"
            data-preview-url="/templates/nimbus-ui-kit/index.html"
           data-preview-title="Nimbus UI Kit"
           data-preview-cat="UI Kit">
          <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Nimbus UI Kit">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </span>
          <div class="cover pat-confetti pattern-wrap" aria-hidden="true"></div>
          <div class="body">
            <span class="cat">UI Kit</span>
            <div class="name-row">
              <h3 class="name">Nimbus UI Kit</h3>
              <span class="price">IDR 380k</span>
            </div>
          </div>
        </a>

          <a href="product-detail.html" class="product-card"
            data-preview-url="/templates/terra-brand-pack/index.html"
           data-preview-title="Terra Brand Pack"
           data-preview-cat="Brand Template">
          <span class="pv-trigger" role="button" tabindex="0" data-preview-trigger aria-label="Preview Terra Brand Pack">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
            Preview
          </span>
          <div class="cover pat-block pattern-wrap" aria-hidden="true"></div>
          <div class="body">
            <span class="cat">Brand Template</span>
            <div class="name-row">
              <h3 class="name">Terra Brand Pack</h3>
              <span class="price">IDR 320k</span>
            </div>
          </div>
        </a>

      </div>

      <a href="shop.html" class="section-link">Shop Products <span class="arr">→</span></a>
    </div>
  </section>

  <!-- =================== SERVICES (CARDS, MOVED BELOW SHOP) =================== -->
  <section class="section" id="services-preview">
    <div class="wrap">
      <div class="h-block">
        <div class="left">
          <div class="eyebrow">03 — Services</div>
          <h2>What we can build for you.</h2>
        </div>
        <p class="right">Five disciplines we focus on. Every project gets the same process: slow at the start, quick at the end.</p>
      </div>

      <div class="svc-card-grid">

        <a href="services.html#ux" class="svc-tile">
          <div class="top">
            <span class="num">01</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h18M3 12h12M3 18h7"/></svg>
            </span>
          </div>
          <h3>UX Design</h3>
          <p>Research, wireframing, user flow, and prototyping for products still looking for fit.</p>
          <div class="price"><span>Starting at</span><span class="amount">IDR 8M <span class="arr">→</span></span></div>
        </a>

        <a href="services.html#ui" class="svc-tile">
          <div class="top">
            <span class="num">02</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
            </span>
          </div>
          <h3>UI Design</h3>
          <p>Visual design, design systems, and component libraries that are easy to maintain.</p>
          <div class="price"><span>Starting at</span><span class="amount">IDR 6M <span class="arr">→</span></span></div>
        </a>

        <a href="services.html#web" class="svc-tile">
          <div class="top">
            <span class="num">03</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 14h4"/></svg>
            </span>
          </div>
          <h3>Website Development</h3>
          <p>End-to-end — from company profile to dashboards that need real interactivity.</p>
          <div class="price"><span>Starting at</span><span class="amount">IDR 15M <span class="arr">→</span></span></div>
        </a>

        <a href="services.html#landing" class="svc-tile">
          <div class="top">
            <span class="num">04</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 3h14v18H5z"/><path d="M9 8h6M9 12h6M9 16h3"/></svg>
            </span>
          </div>
          <h3>Landing Page</h3>
          <p>A single page that converts — from design to live in 1–2 weeks.</p>
          <div class="price"><span>Starting at</span><span class="amount">IDR 5M <span class="arr">→</span></span></div>
        </a>

        <a href="services.html#brand" class="svc-tile">
          <div class="top">
            <span class="num">05</span>
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/></svg>
            </span>
          </div>
          <h3>Brand &amp; Logo Guideline</h3>
          <p>Logo, brand book, and a visual system ready to hand off to any team.</p>
          <div class="price"><span>Starting at</span><span class="amount">IDR 4M <span class="arr">→</span></span></div>
        </a>

        <a href="about.html#contact" class="svc-tile" style="background:var(--ink); color:var(--cream); border-color:var(--ink);">
          <div class="top">
            <span class="num" style="color:var(--terracotta-soft);">06</span>
            <span class="icon" aria-hidden="true" style="background:transparent; border-color:rgba(246,239,224,.2); color:var(--terracotta-soft);">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </span>
          </div>
          <h3 style="color:var(--cream);">Something else?</h3>
          <p style="color:var(--cream); opacity:.7;">If what you need isn&rsquo;t on the list, let&rsquo;s talk first. We&rsquo;ll be honest about whether we can help.</p>
          <div class="price" style="border-color:rgba(246,239,224,.18); color:var(--terracotta-soft);"><span>Discuss</span><span class="amount" style="color:var(--cream);">Contact <span class="arr">→</span></span></div>
        </a>

      </div>
    </div>
  </section>

  <!-- =================== CTA =================== -->
  <section class="section-tight">
    <div class="cta-wrap">
      <div class="cta-panel cta-panel-compact pat-heat">
        <div class="eyebrow">Let&rsquo;s talk</div>
        <h2>Got a project? <em class="italic-accent" style="color:var(--ink)">Let&rsquo;s talk.</em></h2>
        <p>Send us a brief or just tell us your idea. We reply within 1×24 hours (business hours).</p>
        <div class="btn-row">
          <a href="mailto:hello@rohaworks.com" class="btn btn-cream">Email Us <span class="arr">→</span></a>
          <!-- Replace [NO_WA] with active WhatsApp number -->
          <a href="https://wa.me/[NO_WA]?text=Hi%20Roha%2C%20I%27d%20like%20to%20discuss%20a%20project" class="btn btn-outline-cream" target="_blank" rel="noopener">Chat on WhatsApp</a>
        </div>
        <div class="arcs-deco" aria-hidden="true"></div>
      </div>
    </div>
  </section>

</main>
</Base>

