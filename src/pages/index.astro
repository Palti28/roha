</main>

<script>
(function () {
  function sel(cls) { return document.querySelector('.' + cls); }

  const ENTRY = (delay, fade) => ({
    frames: fade
      ? [{ opacity: 0, transform: 'translateY(14px)' }, { opacity: 1, transform: 'translateY(0)' }]
      : [{ transform: 'translateY(14px)' }, { transform: 'translateY(0)' }],
    opts: { duration: 700, delay, fill: 'forwards', easing: 'cubic-bezier(0.22,1,0.36,1)' }
  });

  [
    { q: '.home-hero-left .eyebrow',   delay:  60 },
    { q: '.home-hero-left h1',         delay: 160 },
    { q: '.home-hero-left .btn-row',   delay: 290 },
    { q: '.home-hero-right',           delay: 200 },
  ].forEach(({ q, delay }) => {
    const el = document.querySelector(q);
    if (!el) return;
    setTimeout(() => el.classList.add('is-visible'), delay);
  });

  const entries = [
    { cls: 'hi-hex-a',    delay: 100,  fade: false },
    { cls: 'hi-hex-b',    delay: 150,  fade: false },
    { cls: 'hi-browser',  delay: 200,  fade: true  },
    { cls: 'hi-palette',  delay: 300,  fade: true  },
    { cls: 'hi-code-dark',delay: 350,  fade: true  },
    { cls: 'hi-product',  delay: 400,  fade: true  },
    { cls: 'hi-code-light',delay: 450, fade: true  },
    { cls: 'hi-case',     delay: 500,  fade: true  },
    { cls: 'hi-brand',    delay: 550,  fade: true  },
    { cls: 'hi-handle',   delay: 750,  fade: false },
  ];

  const floats = [
    { cls: 'hi-code-dark',  dy: -6, dur: 7000,  delay: 1050 },
    { cls: 'hi-code-light', dy:  5, dur: 8000,  delay: 1150 },
    { cls: 'hi-palette',    dy: -4, dur: 9000,  delay: 1000 },
    { cls: 'hi-case',       dy: -6, dur: 10000, delay: 1200 },
    { cls: 'hi-brand',      dy:  5, dur: 7500,  delay: 1250 },
    { cls: 'hi-product',    dy: -4, dur: 8500,  delay: 1100 },
    { cls: 'hi-hex-a',      dy: -6, dur: 9000,  delay: 700  },
    { cls: 'hi-hex-b',      dy:  5, dur: 11000, delay: 750  },
  ];

  entries.forEach(({ cls, delay, fade }) => {
    const el = sel(cls);
    if (!el) return;
    const e = ENTRY(delay, fade);
    el.animate(e.frames, e.opts);
  });

  floats.forEach(({ cls, dy, dur, delay }) => {
    const el = sel(cls);
    if (!el) return;
    setTimeout(() => {
      el.animate(
        [{ transform: 'translateY(0px)' }, { transform: `translateY(${dy}px)` }, { transform: 'translateY(0px)' }],
        { duration: dur, iterations: Infinity, easing: 'ease-in-out' }
      );
    }, delay);
  });

  const SPRING = { duration: 500, fill: 'forwards', easing: 'cubic-bezier(0.34, 1.56, 0.64, 1)' };
  const hovers = [
    { cls: 'hi-case',       to: 'translateY(-8px) scale(1.07)' },
    { cls: 'hi-browser',    to: 'translateY(-5px)' },
    { cls: 'hi-product',    to: 'translateY(-7px) scale(1.06)' },
    { cls: 'hi-code-dark',  to: 'translateX(-5px) translateY(-4px)' },
    { cls: 'hi-code-light', to: 'translateX(5px) translateY(-4px)' },
  ];

  hovers.forEach(({ cls, to }) => {
    const el = sel(cls);
    if (!el) return;
    el.style.pointerEvents = 'bounding-box';
    let anim = null;
    el.addEventListener('mouseenter', () => {
      if (anim) anim.cancel();
      anim = el.animate([{ transform: to }], SPRING);
    });
    el.addEventListener('mouseleave', () => {
      if (anim) { anim.cancel(); anim = null; }
    });
  });
})();

// -- Homepage interactions: 3D tilt, parallax, magnetic CTA --
(function () {
  const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
  if (!canHover) return;

  // 3D tilt for service tiles
  var SVC_BASE_TRANS = 'background .2s ease, border-color .2s ease, box-shadow .3s ease';
  var SVC_FULL_TRANS = 'background .2s ease, border-color .2s ease, transform .3s cubic-bezier(.2,.7,.2,1), box-shadow .3s ease';

  document.querySelectorAll('.svc-tile').forEach(function (card) {
    var c = card as HTMLElement;
    var shine = document.createElement('div');
    shine.className = 'tilt-shine';
    card.appendChild(shine);
    var leaveTimer = 0;

    card.addEventListener('mousemove', function (e) {
      clearTimeout(leaveTimer);
      c.style.transition = SVC_BASE_TRANS; // no transform transition = instant tracking
      var r = card.getBoundingClientRect();
      var x = (e.clientX - r.left) / r.width - 0.5;
      var y = (e.clientY - r.top) / r.height - 0.5;
      c.style.transform =
        'perspective(700px) rotateY(' + (x * 10) + 'deg) rotateX(' + (-y * 10) + 'deg) translateZ(4px) translateY(-5px)';
      shine.style.setProperty('--mx', ((x + 0.5) * 100) + '%');
      shine.style.setProperty('--my', ((y + 0.5) * 100) + '%');
    });

    card.addEventListener('mouseleave', function () {
      c.style.transition = SVC_FULL_TRANS; // restore transform transition for smooth spring-back
      c.style.transform = '';
      leaveTimer = window.setTimeout(function () { c.style.transition = ''; }, 350);
    });
  });

  // Hero illustration parallax
  var heroSection = document.querySelector('.home-hero') as HTMLElement | null;
  var illusWrap = document.querySelector('.hero-illus-wrap') as HTMLElement | null;
  if (heroSection && illusWrap) {
    heroSection.addEventListener('mousemove', function (e) {
      var r = heroSection!.getBoundingClientRect();
      var x = (e.clientX - r.left - r.width / 2) / r.width;
      var y = (e.clientY - r.top - r.height / 2) / r.height;
      illusWrap!.style.transform = 'translate(' + (x * -16) + 'px,' + (y * -10) + 'px)';
    });
    heroSection.addEventListener('mouseleave', function () {
      illusWrap!.style.transform = '';
    });
  }

  // Magnetic primary CTA button
  var cta = document.querySelector('.home-hero-left .btn-primary') as HTMLElement | null;
  if (cta) {
    var RANGE = 90;
    document.addEventListener('mousemove', function (e) {
      var r = cta!.getBoundingClientRect();
      var cx = r.left + r.width / 2;
      var cy = r.top + r.height / 2;
      var dx = e.clientX - cx;
      var dy = e.clientY - cy;
      var dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < RANGE) {
        var pull = (1 - dist / RANGE) * 0.35;
        cta!.style.transform = 'translate(' + (dx * pull) + 'px,' + (dy * pull) + 'px)';
      } else {
        cta!.style.transform = '';
      }
    });
  }
})();
</script>
