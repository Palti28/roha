---
const navLinks = [
  { href: '/portfolio', label: 'Work' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Case Studies' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<!-- =================== TOPBAR =================== -->
<header class="topbar" role="banner">
  <div class="topbar-inner">
    <a href="/" class="logo" aria-label="Roha — Home">roha<span class="dot">.</span></a>
    <span class="topbar-url">rohaworks.com</span>
    <button class="topbar-burger" id="topbarBurger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="topbarMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <div class="topbar-menu" id="topbarMenu" aria-hidden="true">
    <ul class="topbar-menu-links">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class={isActive(link.href) ? 'active' : ''}>{link.label}</a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
(function () {
  const burger = document.getElementById('topbarBurger') as HTMLButtonElement | null;
  const menu   = document.getElementById('topbarMenu')   as HTMLElement | null;
  if (!burger || !menu) return;

  burger.addEventListener('click', function () {
    const isOpen = menu.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
    burger.setAttribute('aria-label', isOpen ? 'Close navigation menu' : 'Open navigation menu');
    menu.setAttribute('aria-hidden', String(!isOpen));
  });

  menu.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', function () {
      menu.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
})();
</script>
