---
import { site } from '../data/site.ts';
---

<!-- =================== FOOTER =================== -->
<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">

      <div class="footer-col footer-brand" data-reveal>
        <a href="/" class="logo">roha<span class="dot">.</span></a>
        <p class="tagline">Considered design, built to last.</p>
        <p>A design studio in Indonesia. We build websites, UI/UX, and brand systems for people building something real.</p>
      </div>

      <div class="footer-col" data-reveal data-reveal-delay="80">
        <h4>Pages</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/work">Case Studies</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/portfolio">Work</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </div>

      <div class="footer-col" data-reveal data-reveal-delay="160">
        <h4>Services</h4>
        <ul>
          <li><a href="/services#product-design">Product Design (UI/UX)</a></li>
          <li><a href="/services#web">Website Development</a></li>
          <li><a href="/services#landing">Landing Page</a></li>
          <li><a href="/services#brand">Brand &amp; Logo</a></li>
        </ul>
      </div>

      <div class="footer-col" data-reveal data-reveal-delay="240">
        <h4>Connect</h4>
        <ul>
          <li>
            <a href={`mailto:${site.email}`} class="footer-email-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
              {site.email}
            </a>
          </li>
        </ul>
        <div class="footer-social">
          <a href="" aria-label="Dribbble" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8.5 2.5C8.5 2.5 12 8 12 12s-3.5 9.5-3.5 9.5"/><path d="M15.5 2.5S12 8 12 12s3.5 9.5 3.5 9.5"/><path d="M2 12h20"/></svg>
          </a>
          <a href="" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".8" fill="currentColor"/></svg>
          </a>
          <a href="" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>

    </div>

    <div class="footer-bottom">
      <span>&copy; 2026 ROHA &middot; MADE IN INDONESIA</span>
      <span>v1.0</span>
    </div>
  </div>
</footer>

